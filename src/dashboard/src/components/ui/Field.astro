---
import Tooltip from "./Tooltip.astro";

interface Props {
  label?: string;
  htmlFor?: string;
  hint?: string;
  tooltip?: string;
  class?: string;
}

const { label, htmlFor, hint, tooltip, class: className = "" } = Astro.props;
---

<label class={`block ${className}`} for={htmlFor}>
  {
    label && (
      <span class="u-field-label-row">
        <span class="u-field-label">{label}</span>
        {tooltip && <Tooltip content={tooltip} />}
      </span>
    )
  }
  <slot />
  {
    (hint || Astro.slots.has("hint")) && (
      <span class="u-field-hint">
        {hint}
        <slot name="hint" />
      </span>
    )
  }
  {
    Astro.slots.has("error") && (
      <span class="u-field-error">
        <slot name="error" />
      </span>
    )
  }
</label>
