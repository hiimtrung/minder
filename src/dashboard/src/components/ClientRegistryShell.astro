---
import DashboardLayout from "../layouts/DashboardLayout.astro";
import PageHero from "./ui/molecules/PageHero.astro";
import Toolbar from "./ui/molecules/Toolbar.astro";
import Field from "./ui/atoms/Field.astro";
import Input from "./ui/atoms/Input.astro";
import Textarea from "./ui/atoms/Textarea.astro";
import Button from "./ui/atoms/Button.astro";
import FormStatus from "./ui/atoms/FormStatus.astro";
---

<DashboardLayout
  title="Client Registry · Minder"
  description="Astro shell for the Minder client registry."
  navTitle="Minder Dashboard"
  navDescription="Provision client keys, then open each client in a dedicated detail route."
  sessionControls={true}
  showPageIntro={false}
>
  <PageHero
    eyebrow="Client Registry"
    title="Manage MCP clients."
    description="Create clients, issue keys, and route into a dedicated client detail screen without losing the dashboard shell. Each registry card opens a focused detail path with lifecycle controls, onboarding snippets, and recent activity."
  />

  <div class="flex flex-col gap-5">
    <Toolbar
      idPrefix="client"
      description="Open any client card to move into the dedicated detail path with breadcrumb context and focused lifecycle tools."
      searchPlaceholder="Semantic quick search clients"
    >
      <Button slot="leading" href="/dashboard" size="sm">
        Dashboard home
      </Button>
      <Button slot="leading" id="client-new-button" size="sm" variant="primary">
        New client
      </Button>
    </Toolbar>

    <div id="client-registry" class="grid gap-4 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
      <article class="u-placeholder-card">Loading client registry...</article>
    </div>
  </div>

  <!-- Create client dialog -->
  <dialog id="client-form-dialog" class="u-modal-dialog">
    <div class="u-modal-inner">
      <header class="u-modal-header">
        <div>
          <p class="eyebrow">Create Client</p>
          <h2 class="u-modal-title">Create a new MCP client</h2>
        </div>
        <button
          id="client-close-dialog"
          type="button"
          class="u-modal-close-btn"
          aria-label="Close"
        >
          ✕
        </button>
      </header>

      <div class="u-modal-body">
        <p class="mb-4 text-sm leading-6 text-stone-600">
          Minder will issue a new <code>mkc_...</code> key exactly once after creation.
          Keep scopes tight and prefer repo-specific access when possible.
        </p>

        <form id="create-client-form" class="grid gap-4">
          <Field label="Name" htmlFor="client-name">
            <Input id="client-name" placeholder="Name" />
          </Field>
          <Field label="Slug" htmlFor="client-slug">
            <Input id="client-slug" placeholder="Slug" />
          </Field>
          <Field label="Description" htmlFor="client-description">
            <Textarea id="client-description" placeholder="Description" />
          </Field>

          <div class="flex flex-wrap items-center justify-between gap-2">
            <div class="flex flex-wrap gap-2">
              <Button size="sm" extraAttrs={{ "data-tool-preset": "query" }}>
                Query Only
              </Button>
              <Button size="sm" extraAttrs={{ "data-tool-preset": "read" }}>
                Read Only
              </Button>
              <Button size="sm" extraAttrs={{ "data-tool-preset": "all" }}>
                All
              </Button>
            </div>
            <Button
              id="create-refresh-tools"
              size="sm"
              variant="ghost"
              title="Reload tool list from server"
            >
              Refresh tools
            </Button>
          </div>

          <div class="grid gap-2 text-sm text-stone-700">
            <span class="u-field-label">Tool scopes</span>
            <div
              id="client-tool-scopes"
              class="max-h-52 min-h-24 overflow-y-auto rounded-xl border border-stone-300 bg-white p-2"
            >
              <p class="px-1 text-sm text-stone-400">Loading tools...</p>
            </div>
          </div>

          <Field
            label="Repo scopes"
            htmlFor="client-repo-scopes"
            hint="Comma-separated; use * for all repos."
          >
            <Input
              id="client-repo-scopes"
              placeholder="Repo scopes (comma-separated)"
              value="*"
            />
          </Field>

          <FormStatus id="create-client-status" />
        </form>
      </div>

      <div class="u-modal-footer">
        <Button
          type="submit"
          form="create-client-form"
          variant="primary"
          class="flex-1 min-w-[180px]"
        >
          Create client
        </Button>
      </div>
    </div>
  </dialog>

  <script src="../scripts/clients-page.ts"></script>
</DashboardLayout>
