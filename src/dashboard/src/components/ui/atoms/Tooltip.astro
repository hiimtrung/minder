---
interface Props {
  content: string;
  class?: string;
}

const {
  content,
  class: className = "",
} = Astro.props;

const id = `tip-${Math.random().toString(36).slice(2, 8)}`;
---

<span class:list={["tip-root", className]} aria-describedby={id}>
  <span class="tip-icon" tabindex="0" role="img" aria-label="More info">ℹ</span>
  <span role="tooltip" id={id} class="tip-panel">{content}</span>
</span>

<style>
  .tip-root {
    position: relative;
    display: inline-flex;
    align-items: center;
    vertical-align: middle;
  }

  .tip-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1rem;
    height: 1rem;
    border-radius: 9999px;
    background: rgb(231 229 228);
    color: rgb(120 113 108);
    font-size: 0.6rem;
    font-weight: 800;
    font-style: italic;
    flex-shrink: 0;
    line-height: 1;
    user-select: none;
    cursor: default;
    font-family: var(--font-sans);
    outline-offset: 2px;
  }
  .tip-icon:focus-visible {
    outline: 2px solid rgb(180 83 9);
  }

  .tip-panel {
    position: absolute;
    bottom: calc(100% + 8px);
    left: 50%;
    transform: translateX(-50%);
    width: max-content;
    max-width: 18rem;
    background: rgb(28 25 23);
    color: rgb(231 229 228);
    font-size: 0.75rem;
    line-height: 1.55;
    padding: 0.5rem 0.75rem;
    border-radius: 0.625rem;
    visibility: hidden;
    opacity: 0;
    transition: opacity 0.12s, visibility 0.12s;
    z-index: 50;
    pointer-events: none;
    white-space: normal;
    text-align: left;
    font-weight: 400;
    box-shadow: 0 8px 24px rgba(28, 25, 23, 0.2);
  }
  .tip-panel::after {
    content: '';
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    border: 4px solid transparent;
    border-top-color: rgb(28 25 23);
  }

  .tip-root:hover .tip-panel,
  .tip-root:focus-within .tip-panel {
    visibility: visible;
    opacity: 1;
  }
</style>
