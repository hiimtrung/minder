---
import DashboardPageHeader from "./DashboardPageHeader.astro";

interface BreadcrumbItem {
  href?: string;
  label: string;
}

interface Props {
  breadcrumb: BreadcrumbItem[];
  eyebrow?: string;
  title: string;
  titleId?: string;
  description?: string;
  class?: string;
}

const {
  breadcrumb,
  eyebrow,
  title,
  titleId,
  description,
  class: className = "",
} = Astro.props;
const hasActions = Astro.slots.has("actions");
---

<DashboardPageHeader
  breadcrumb={breadcrumb}
  eyebrow={eyebrow}
  title={title}
  titleId={titleId}
  description={description}
  class={className}
>
  {hasActions && (
    <Fragment slot="actions">
      <slot name="actions" />
    </Fragment>
  )}
</DashboardPageHeader>

<style is:global>
  /* Legacy classes used by JS-injected HTML */
  .u-detail-hero {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-bottom: 1.25rem;
  }
  .u-detail-hero-title {
    font-family: var(--font-display);
    font-size: clamp(1.55rem, 1.15rem + 1vw, 2.35rem);
    line-height: 1.08;
    letter-spacing: -0.035em;
    font-weight: 700;
    color: rgb(28 25 23);
  }
</style>
