---
import DashboardLayout from "../layouts/DashboardLayout.astro";
import PageHero from "./ui/PageHero.astro";
import Card from "./ui/Card.astro";
import Field from "./ui/Field.astro";
import Input from "./ui/Input.astro";
import Select from "./ui/Select.astro";
import Button from "./ui/Button.astro";
import FormStatus from "./ui/FormStatus.astro";
import ResultCallout from "./ui/ResultCallout.astro";
---

<DashboardLayout
  title="User Management · Minder"
  description="Manage admin users — view roles, activate/deactivate accounts, and update display names."
  navTitle="Minder Dashboard"
  navDescription="Administer the users who have access to the Minder dashboard and admin API."
  sessionControls={true}
  showPageIntro={false}
>
  <PageHero
    eyebrow="User Management"
    title="Manage admin users."
    description="View all registered admin users, update their roles and display names, and deactivate accounts that no longer need access to the Minder dashboard."
  >
    <label
      slot="actions"
      class="flex items-center gap-2 text-sm text-stone-700"
    >
      <input
        type="checkbox"
        id="show-inactive-toggle"
        class="accent-amber-700"
      />
      Show inactive
    </label>
    <Button slot="actions" id="toggle-create-user" variant="primary" size="sm">
      + New user
    </Button>
  </PageHero>

  <section class="u-grid-sidebar">
    <!-- Sidebar: Edit User panel (sticky) -->
    <aside class="flex flex-col gap-4 self-start lg:sticky lg:top-4">
      <Card padding="lg">
        <p class="eyebrow">Edit User</p>
        <h2
          class="font-display mt-2 text-xl font-semibold tracking-tight text-stone-950"
        >
          User details
        </h2>
        <p id="edit-user-hint" class="mt-2 text-sm leading-6 text-stone-500">
          Select a user from the list on the right to edit their profile.
        </p>

        <form id="edit-user-form" class="mt-5 hidden gap-4">
          <Field label="Display name" htmlFor="edit-user-display-name">
            <Input id="edit-user-display-name" placeholder="Display name" />
          </Field>

          <Field label="Role" htmlFor="edit-user-role">
            <Select id="edit-user-role">
              <option value="admin">Admin</option>
              <option value="member">Member</option>
              <option value="readonly">Read Only</option>
            </Select>
          </Field>

          <div class="flex items-center gap-3">
            <input
              type="checkbox"
              id="edit-user-is-active"
              class="h-4 w-4 rounded border-stone-300 accent-amber-700"
            />
            <label for="edit-user-is-active" class="text-sm text-stone-700">
              Active (uncheck to deactivate)
            </label>
          </div>

          <FormStatus id="edit-user-status" />
          <div class="flex gap-2">
            <Button type="submit" variant="primary" class="flex-1">
              Save changes
            </Button>
            <Button id="cancel-edit-user">Cancel</Button>
          </div>

          <!-- MCP clients owned by this user -->
          <div class="mt-2 border-t border-stone-100 pt-4">
            <p class="mb-3 text-sm font-medium text-stone-700">MCP clients</p>
            <div id="edit-user-clients" class="grid gap-2">
              <p class="px-1 text-xs text-stone-400">Loading clients…</p>
            </div>
            <a
              href="/dashboard/clients"
              class="mt-3 inline-block text-xs font-medium text-amber-800 hover:underline"
            >
              Manage all clients →
            </a>
          </div>
        </form>
      </Card>
    </aside>

    <!-- Main area: Create User collapsible + User list -->
    <div class="flex flex-col gap-5">
      <!-- Create User panel (collapsed by default) -->
      <section
        id="create-user-panel"
        class="shell-card hidden overflow-hidden transition-all"
      >
        <div class="flex items-start justify-between gap-4 p-6 pb-0">
          <div>
            <p class="eyebrow">Create User</p>
            <h2
              class="font-display mt-2 text-xl font-semibold tracking-tight text-stone-950"
            >
              Add another admin or member
            </h2>
            <p class="mt-2 text-sm leading-6 text-stone-500">
              Create a new dashboard user and reveal their bootstrap API key
              exactly once.
            </p>
          </div>
          <button
            id="close-create-user"
            type="button"
            class="shrink-0 rounded-full p-1.5 text-stone-400 transition hover:bg-stone-100 hover:text-stone-700"
            aria-label="Close create user panel"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <line x1="18" y1="6" x2="6" y2="18"></line>
              <line x1="6" y1="6" x2="18" y2="18"></line>
            </svg>
          </button>
        </div>

        <form id="create-user-form" class="grid gap-4 p-6 pt-4 sm:grid-cols-2">
          <Field label="Username" htmlFor="create-user-username">
            <Input
              id="create-user-username"
              placeholder="new_admin"
              required
            />
          </Field>

          <Field label="Email" htmlFor="create-user-email">
            <Input
              id="create-user-email"
              type="email"
              placeholder="admin@example.com"
              required
            />
          </Field>

          <Field label="Display name" htmlFor="create-user-display-name">
            <Input
              id="create-user-display-name"
              placeholder="Operations Admin"
              required
            />
          </Field>

          <Field label="Role" htmlFor="create-user-role">
            <Select id="create-user-role">
              <option value="admin">Admin</option>
              <option value="member">Member</option>
              <option value="readonly">Read Only</option>
            </Select>
          </Field>

          <Field
            label="Password"
            htmlFor="create-user-password"
            hint="Leave blank for API-key-only login."
            class="sm:col-span-2"
          >
            <Input
              id="create-user-password"
              type="password"
              placeholder="Min. 8 characters"
            />
          </Field>

          <div class="sm:col-span-2">
            <FormStatus id="create-user-status" class="mb-3" />
            <Button type="submit" variant="primary">Create user</Button>
          </div>
        </form>

        <ResultCallout
          id="create-user-result"
          tone="emerald"
          class="mx-6 mb-6"
        >
          <p
            class="text-xs font-semibold uppercase tracking-[0.24em] text-emerald-700"
          >
            Bootstrap API key
          </p>
          <p
            id="create-user-result-hint"
            class="mt-2 text-sm leading-6 text-emerald-900"
          >
          </p>
          <pre
            id="create-user-api-key"
            class="font-mono-ui mt-3 overflow-x-auto rounded-xl bg-emerald-950 px-4 py-3 text-xs text-emerald-50">
          </pre>
        </ResultCallout>
      </section>

      <!-- User roster header -->
      <section
        class="shell-card flex flex-wrap items-center justify-between gap-4 px-6 py-4"
      >
        <div>
          <p class="text-sm font-medium text-stone-900">User roster</p>
          <p class="mt-1 text-sm text-stone-600">
            Click any user row to load their profile into the edit panel on the
            left.
          </p>
        </div>
        <Button href="/dashboard" size="sm">Dashboard home</Button>
      </section>

      <!-- User list -->
      <div id="user-list" class="grid gap-3">
        <div class="u-placeholder-card">Loading users...</div>
      </div>
    </div>
  </section>

  <!-- Toast region -->
  <div
    id="dashboard-toast-region"
    class="pointer-events-none fixed right-6 bottom-6 z-50 flex flex-col items-end gap-3"
  >
  </div>

  <script src="../scripts/users-page.ts"></script>
</DashboardLayout>
