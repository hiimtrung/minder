---
interface Props {
  title?: string;
  description?: string;
  idPrefix?: string;
  searchId?: string;
  statusId?: string;
  prevId?: string;
  nextId?: string;
  searchPlaceholder?: string;
  showSearch?: boolean;
  class?: string;
}

const {
  title,
  description,
  idPrefix = "",
  searchId,
  statusId,
  prevId,
  nextId,
  searchPlaceholder = "Search...",
  showSearch = true,
  class: className = "",
} = Astro.props;

const ids = {
  search: searchId ?? (idPrefix ? `${idPrefix}-quick-search` : "quick-search"),
  status: statusId ?? (idPrefix ? `${idPrefix}-pagination-status` : "pagination-status"),
  prev:   prevId   ?? (idPrefix ? `${idPrefix}-page-prev`        : "page-prev"),
  next:   nextId   ?? (idPrefix ? `${idPrefix}-page-next`        : "page-next"),
  loading: idPrefix ? `${idPrefix}-quick-search-loading`         : "quick-search-loading",
};
---

<div class:list={["toolbar", className]}>
  <div class="toolbar-row">
    {(title || description) && (
      <div class="toolbar-meta">
        {title && <p class="toolbar-title">{title}</p>}
        {description && <p class="toolbar-desc">{description}</p>}
      </div>
    )}
    <div class="toolbar-actions">
      <slot name="leading" />
      <slot name="trailing" />
    </div>
  </div>

  {showSearch && (
    <div class="toolbar-row toolbar-search-row">
      <div class="toolbar-search-wrap">
        <input
          id={ids.search}
          type="search"
          placeholder={searchPlaceholder}
          class="toolbar-search"
          autocomplete="off"
        />
        <span id={ids.loading} class="toolbar-search-spinner hidden" aria-hidden="true">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="animate-spin"><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/></svg>
        </span>
      </div>
      <div class="toolbar-pager">
        <span id={ids.status} class="toolbar-pager-status"></span>
        <button id={ids.prev} type="button" class="action-pill u-btn-sm" disabled>←</button>
        <button id={ids.next} type="button" class="action-pill u-btn-sm" disabled>→</button>
      </div>
    </div>
  )}
</div>

<style>
  .toolbar {
    border-radius: 1rem;
    border: 1px solid rgb(231 229 228 / 0.8);
    background: rgb(255 255 255 / 0.98);
    padding: 0.75rem 1rem;
    box-shadow: var(--shadow-card);
  }

  .toolbar-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
  }

  .toolbar-row + .toolbar-row {
    margin-top: 0.75rem;
    border-top: 1px solid rgb(231 229 228);
    padding-top: 0.75rem;
  }

  .toolbar-meta {
    flex: 1;
    min-width: 0;
  }

  .toolbar-title {
    font-size: 0.875rem;
    font-weight: 600;
    color: rgb(28 25 23);
  }

  .toolbar-desc {
    margin-top: 0.125rem;
    font-size: 0.8125rem;
    color: rgb(120 113 108);
    max-width: 44ch;
  }

  .toolbar-actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
  }

  .toolbar-search-row {
    align-items: center;
  }

  .toolbar-search-wrap {
    position: relative;
    flex: 1;
    min-width: 10rem;
    max-width: 26rem;
  }

  .toolbar-search {
    width: 100%;
    border-radius: 9999px;
    border: 1px solid rgb(214 211 209);
    background: white;
    padding: 0.375rem 2rem 0.375rem 0.875rem;
    font-size: 0.8125rem;
    color: rgb(28 25 23);
    outline: none;
    font-family: var(--font-sans);
    transition: border-color 150ms, box-shadow 150ms;
  }
  .toolbar-search::placeholder { color: rgb(168 162 158); }
  .toolbar-search:focus {
    border-color: rgb(180 83 9);
    box-shadow: 0 0 0 3px var(--color-brand-ring);
  }

  .toolbar-search-spinner {
    position: absolute;
    right: 0.625rem;
    top: 50%;
    transform: translateY(-50%);
    color: rgb(120 113 108);
  }

  .toolbar-pager {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .toolbar-pager-status {
    font-size: 0.75rem;
    color: rgb(120 113 108);
    white-space: nowrap;
  }
</style>
