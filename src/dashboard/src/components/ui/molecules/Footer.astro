---
interface Props {
  version?: string;
  showHealth?: boolean;
}

const {
  version = import.meta.env.PUBLIC_VERSION ?? "0.1.0",
  showHealth = false,
} = Astro.props;

const year = new Date().getFullYear();
---

<footer class="dashboard-footer">
  <div class="footer-left">
    <span>© {year} Minder</span>
    <span class="footer-sep" aria-hidden="true">·</span>
    <span>v{version}</span>
    {showHealth && (
      <>
        <span class="footer-sep" aria-hidden="true">·</span>
        <span class="footer-health">
          <span id="dashboard-api-health-dot" class="footer-dot" aria-hidden="true" />
          <span id="dashboard-api-health-label">API</span>
        </span>
      </>
    )}
  </div>
  <div class="footer-right">
    <a href="https://github.com/tastech-asia/minder/tree/main/docs" target="_blank" rel="noreferrer noopener">Docs</a>
    <span class="footer-sep" aria-hidden="true">·</span>
    <a href="https://github.com/tastech-asia/minder" target="_blank" rel="noreferrer noopener">GitHub</a>
    <span class="footer-sep" aria-hidden="true">·</span>
    <a href="/dashboard/observability">Status</a>
  </div>
</footer>

<style>
  .dashboard-footer {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    border-top: 1px solid rgb(231 229 228 / 0.8);
    padding: 0.625rem 1.5rem;
    font-size: 0.6875rem;
    color: rgb(120 113 108);
    max-width: var(--layout-max);
    width: 100%;
    margin-inline: auto;
  }

  .footer-left,
  .footer-right {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem;
  }

  .footer-sep { color: rgb(214 211 209); }

  .dashboard-footer a {
    color: rgb(87 83 78);
    transition: color 150ms;
    text-decoration: none;
  }
  .dashboard-footer a:hover { color: rgb(146 64 14); }

  .footer-health {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
  }

  .footer-dot {
    display: inline-flex;
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 9999px;
    background: rgb(214 211 209);
    flex-shrink: 0;
  }
  :global(.footer-dot.ok)   { background: rgb(16 185 129); }
  :global(.footer-dot.warn) { background: rgb(245 158 11); }
  :global(.footer-dot.err)  { background: rgb(244 63 94); }
</style>

<style is:global>
  /* Legacy classes for JS-toggled health dot */
  .u-dashboard-footer {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    border-top: 1px solid rgb(231 229 228 / 0.8);
    padding: 0.625rem 1.5rem;
    font-size: 0.6875rem;
    color: rgb(120 113 108);
    max-width: var(--layout-max);
    width: 100%;
    margin-inline: auto;
  }
  .u-dashboard-footer a {
    color: rgb(87 83 78);
    transition: color 150ms;
  }
  .u-dashboard-footer a:hover { color: rgb(146 64 14); }
  .u-footer-dot {
    display: inline-flex;
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 9999px;
    background: rgb(214 211 209);
    flex-shrink: 0;
  }
  .u-footer-dot.ok   { background: rgb(16 185 129); }
  .u-footer-dot.warn { background: rgb(245 158 11); }
  .u-footer-dot.err  { background: rgb(244 63 94); }
</style>
