---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  navTitle?: string;
  navDescription?: string;
  navLinks?: Array<{
    href: string;
    label: string;
    tone?: "primary" | "secondary";
    currentDetail?: boolean;
  }>;
  sessionControls?: boolean;
}

const {
  title,
  description = "Minder dashboard shell",
  navTitle = "Minder Dashboard",
  navDescription = "Admin setup, login, client management, and onboarding on one port.",
  navLinks = [],
  sessionControls = false,
} = Astro.props;

const DEFAULT_NAV = [
  { href: "/dashboard", label: "Home" },
  { href: "/dashboard/clients", label: "Clients" },
  { href: "/dashboard/workflows", label: "Workflows" },
  { href: "/dashboard/users", label: "Users" },
  { href: "/dashboard/observability", label: "Observability" },
];

const effectiveNav = navLinks.length > 0 ? navLinks : DEFAULT_NAV;
const currentPath = Astro.url.pathname;

const isLinkActive = (href: string, currentDetail?: boolean) => {
  if (currentDetail) return true;
  
  // Normalize path by stripping backend-injected prefixes (e.g. /v1/admin) 
  // to ensure active state detection works both in dev and prod/backend mounts.
  const normalizedPath = currentPath.replace(/^\/v[0-9]+\/admin/, "") || "/";
  const path = normalizedPath.replace(/\/$/, "") || "/";
  const target = href.replace(/\/$/, "") || "/";

  if (target === "/dashboard") {
    return path === "/dashboard" || path === "/dashboard/index.html";
  }
  return path.startsWith(target);
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href="/dashboard/favicon.png" />
  </head>
  <body>
    <div class="min-h-screen">
      <header class="mx-auto max-w-6xl px-6 py-8">
        <div class="flex flex-wrap items-center justify-between gap-6">
          <!-- Branding -->
          <div class="flex items-center gap-4">
            <a href="/dashboard" class="group flex items-center gap-3">
              <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-amber-800 text-white shadow-lg transition-transform group-hover:scale-105">
                <span class="text-xl font-bold">M</span>
              </div>
              <div class="flex flex-col">
                <span class="text-lg font-bold tracking-tight text-stone-900">{navTitle}</span>
                <span class="text-[10px] font-bold tracking-[0.2em] text-stone-500 uppercase">Control Plane</span>
              </div>
            </a>
          </div>

          <!-- Main Navigation -->
          <nav class="hidden items-center gap-1 md:flex">
            {
              effectiveNav.map((link: any) => (
                <a
                  href={link.href}
                  class="nav-link"
                  data-active={isLinkActive(link.href, link.currentDetail) ? "true" : "false"}
                >
                  {link.label}
                </a>
              ))
            }
          </nav>

          <!-- User Actions -->
          <div class="flex items-center gap-3">
            {
              sessionControls && (
                <div class="flex items-center gap-3">
                  <span
                    id="dashboard-session-badge"
                    class="session-badge"
                  >
                    Checking...
                  </span>
                  <div class="h-4 w-px bg-stone-300"></div>
                  <button
                    id="dashboard-logout-button"
                    type="button"
                    class="action-pill px-3 py-1.5 text-xs!"
                  >
                    Logout
                  </button>
                </div>
              )
            }
            { !sessionControls && navLinks.length > 0 && (
                <div class="md:hidden">
                   <!-- Placeholder for mobile menu if needed -->
                </div>
            )}
          </div>
        </div>
        
        <!-- Mobile Navigation (Visible only on small screens) -->
        <nav class="mt-6 flex flex-wrap items-center gap-2 border-t border-stone-200 pt-4 md:hidden">
            {
              effectiveNav.map((link: any) => (
                <a
                  href={link.href}
                  class={isLinkActive(link.href, link.currentDetail) ? "primary-pill" : "action-pill"}
                >
                  {link.label}
                </a>
              ))
            }
        </nav>
      </header>

      <main class="mx-auto max-w-6xl px-6 pb-20">
        <div class="mb-8 flex flex-col gap-2">
            <h1 class="text-3xl font-bold tracking-tight text-stone-950">{title}</h1>
            <p class="text-sm text-stone-600">{navDescription}</p>
        </div>
        <slot />
      </main>
      <div
        id="dashboard-toast-region"
        class="pointer-events-none fixed right-6 bottom-6 z-50 flex max-w-sm flex-col gap-3"
      >
      </div>
    </div>
    {sessionControls && <script src="../scripts/session-header.ts" />}
  </body>
</html>
