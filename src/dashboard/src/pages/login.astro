---
import DashboardLayout from "../layouts/DashboardLayout.astro";
import Card from "../components/ui/Card.astro";
import Field from "../components/ui/Field.astro";
import Input from "../components/ui/Input.astro";
import Button from "../components/ui/Button.astro";
import FormStatus from "../components/ui/FormStatus.astro";
---

<DashboardLayout
  title="Admin Login · Minder"
  description="Browser login shell for the Astro-based Minder dashboard."
  navTitle="Minder Admin Login"
  navDescription="Sign in with your username and password to open the dashboard."
  navLinks={[]}
  showPageIntro={false}
>
  <section class="grid gap-8 lg:grid-cols-[1.1fr_0.9fr] lg:items-center">
    <div class="space-y-4">
      <p class="eyebrow">Admin Access</p>
      <h1 class="font-display max-w-3xl text-4xl font-semibold leading-tight tracking-tight text-stone-950">
        Sign into Minder without leaving the browser.
      </h1>
      <p class="max-w-2xl text-base leading-7 text-stone-700">
        The dashboard uses an <code>HttpOnly</code> cookie-backed admin session.
        Sign in with your username and password, then manage clients, workflows,
        and activity from one place.
      </p>
    </div>

    <Card padding="lg">
      <div class="mb-5">
        <p class="eyebrow">Admin Login</p>
        <h2
          class="font-display mt-2 text-xl font-semibold tracking-tight text-stone-950"
        >
          Sign in with username &amp; password
        </h2>
      </div>

      <form id="login-form" class="space-y-4">
        <Field label="Username" htmlFor="login-username">
          <Input
            id="login-username"
            type="text"
            autocomplete="username"
            placeholder="admin"
          />
        </Field>
        <Field label="Password" htmlFor="login-password">
          <Input
            id="login-password"
            type="password"
            autocomplete="current-password"
            placeholder="••••••••"
          />
        </Field>
        <FormStatus id="login-status" />
        <Button type="submit" variant="primary" fullWidth>
          Continue to dashboard
        </Button>
      </form>

      <details class="mt-5">
        <summary
          class="cursor-pointer select-none text-sm text-stone-500 hover:text-stone-700"
        >
          Sign in with API key instead
        </summary>
        <form id="apikey-form" class="mt-4 space-y-3">
          <Field label="Admin API key" htmlFor="api-key">
            <Input id="api-key" type="password" placeholder="mk_..." />
          </Field>
          <FormStatus id="apikey-status" />
          <Button type="submit" fullWidth>Sign in with API key</Button>
        </form>
      </details>

      <p id="setup-hint" class="mt-5 hidden text-center text-sm text-stone-500">
        Fresh install?
        <a
          href="/dashboard/setup"
          class="font-medium text-amber-800 hover:underline"
          >Complete first-time setup →</a
        >
      </p>
    </Card>
  </section>

  <script src="../scripts/login-page.ts"></script>
</DashboardLayout>
