---
interface Props {
  eyebrow: string;
  valueId?: string;
  value?: string;
  subId?: string;
  sub?: string;
  href?: string;
  class?: string;
}

const {
  eyebrow,
  valueId,
  value = "—",
  subId,
  sub,
  href,
  class: className = "",
} = Astro.props;
---

{href ? (
  <a href={href} class:list={["stat-card", "stat-card-link", className]}>
    <div class="stat-card-body">
      <p class="eyebrow">{eyebrow}</p>
      <p id={valueId} class="stat-value">{value}</p>
      {sub && <p id={subId} class="stat-sub">{sub}</p>}
    </div>
    <span class="stat-arrow" aria-hidden="true">
      <svg viewBox="0 0 20 20" fill="currentColor" width="24" height="24">
        <path fill-rule="evenodd" d="M7.21 14.77a.75.75 0 01.02-1.06L11.168 10 7.23 6.29a.75.75 0 111.04-1.08l4.5 4.25a.75.75 0 010 1.08l-4.5 4.25a.75.75 0 01-1.06-.02z" clip-rule="evenodd" />
      </svg>
    </span>
  </a>
) : (
  <div class:list={["stat-card", className]}>
    <p class="eyebrow">{eyebrow}</p>
    <p id={valueId} class="stat-value">{value}</p>
    {sub !== undefined && <p id={subId} class="stat-sub">{sub}</p>}
  </div>
)}

<style>
  .stat-card {
    border-radius: 1rem;
    border: 1px solid rgb(231 229 228 / 0.8);
    background: rgb(255 255 255 / 0.98);
    padding: 1rem;
    box-shadow: var(--shadow-card);
    text-decoration: none;
    color: inherit;
  }

  .stat-card-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    transition: box-shadow 150ms, border-color 150ms;
  }
  .stat-card-link:hover {
    box-shadow: 0 4px 18px rgba(28, 25, 23, 0.12);
    border-color: rgb(214 211 209);
  }

  .stat-card-body { flex: 1; min-width: 0; }

  .stat-value {
    margin-top: 0.375rem;
    font-family: var(--font-display);
    font-size: 1.875rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    font-variant-numeric: tabular-nums;
    color: rgb(9 9 11);
  }

  .stat-sub {
    margin-top: 0.25rem;
    font-size: 0.75rem;
    color: rgb(120 113 108);
  }

  .stat-arrow {
    color: rgb(214 211 209);
    transition: color 150ms;
    flex-shrink: 0;
  }
  .stat-card-link:hover .stat-arrow { color: rgb(180 83 9); }
</style>

<style is:global>
  /* Legacy classes used by JS-injected HTML */
  .u-stat-card {
    border-radius: 1rem;
    border: 1px solid rgb(231 229 228 / 0.8);
    background: rgb(255 255 255 / 0.98);
    padding: 1rem;
    box-shadow: var(--shadow-card);
  }
  .u-stat-value {
    margin-top: 0.375rem;
    font-family: var(--font-display);
    font-size: 1.875rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    font-variant-numeric: tabular-nums;
    color: rgb(9 9 11);
  }
  .u-stat-sub {
    margin-top: 0.25rem;
    font-size: 0.75rem;
    color: rgb(120 113 108);
  }
</style>
