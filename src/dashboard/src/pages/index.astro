---
import DashboardLayout from "../layouts/DashboardLayout.astro";
---

<DashboardLayout
  title="Home · Minder Dashboard"
  description="System health and usage overview for the Minder control plane."
  navTitle="Minder Dashboard"
  navDescription="System health, resource inventory, and recent activity across the Minder deployment."
  sessionControls={true}
  showPageIntro={false}
>
  <!-- While we verify the admin session client-side. Auth-redirect path hides this page. -->
  <div id="home-bootstrap" class="shell-card mx-auto max-w-xl p-8 text-center">
    <p class="eyebrow">Dashboard</p>
    <h1 class="mt-3 text-2xl font-semibold tracking-tight text-stone-950">
      Resolving dashboard state…
    </h1>
    <p id="home-bootstrap-status" class="mt-2 text-sm text-stone-600">
      Checking admin session.
    </p>
  </div>

  <!-- ══════════════════════════════════════════
       HOME DASHBOARD — hidden until session confirmed
  ══════════════════════════════════════════ -->
  <div id="home-content" class="hidden space-y-6">
    <!-- ── Page header ── -->
    <section class="flex flex-wrap items-end justify-between gap-4">
      <div class="space-y-2">
        <p class="eyebrow">Home</p>
        <h1 class="text-4xl font-semibold tracking-tight text-stone-950">
          System overview
        </h1>
        <p class="max-w-3xl text-sm leading-7 text-stone-600">
          Snapshot of Minder deployment health, resource inventory, and recent
          activity. Counters reset when the process restarts; audit log is
          persistent.
        </p>
      </div>
      <div class="flex items-center gap-2">
        <label class="flex items-center gap-2 text-sm text-stone-600">
          <input
            type="checkbox"
            id="home-auto-refresh"
            class="accent-amber-700"
          />
          Auto-refresh (30s)
        </label>
        <button type="button" id="home-refresh" class="action-pill text-sm">
          Refresh now
        </button>
      </div>
    </section>

    <!-- ── Health strip ── -->
    <section
      class="shell-card flex flex-wrap items-center gap-x-8 gap-y-3 px-5 py-4"
    >
      <div class="flex items-center gap-3">
        <span
          id="home-health-dot"
          class="inline-flex h-2.5 w-2.5 rounded-full bg-stone-300"
          aria-hidden="true"></span>
        <div>
          <p class="text-[11px] font-semibold uppercase tracking-widest text-stone-400">
            API Health
          </p>
          <p
            id="home-health-label"
            class="text-sm font-medium text-stone-800"
          >
            Checking…
          </p>
        </div>
      </div>

      <div class="hidden h-8 w-px bg-stone-200 md:block"></div>

      <div>
        <p class="text-[11px] font-semibold uppercase tracking-widest text-stone-400">
          Signed in
        </p>
        <p id="home-admin-label" class="text-sm font-medium text-stone-800">
          —
        </p>
      </div>

      <div class="hidden h-8 w-px bg-stone-200 md:block"></div>

      <div>
        <p class="text-[11px] font-semibold uppercase tracking-widest text-stone-400">
          Last refreshed
        </p>
        <p id="home-last-updated" class="text-sm font-medium text-stone-800">
          —
        </p>
      </div>

      <p
        id="home-error"
        class="ml-auto hidden text-sm font-medium text-red-700"
      >
      </p>
    </section>

    <!-- ── Inventory KPIs ── -->
    <section>
      <div class="mb-3 flex items-end justify-between">
        <div>
          <p class="eyebrow">Inventory</p>
          <h2 class="mt-1 text-xl font-semibold tracking-tight text-stone-950">
            Registered resources
          </h2>
        </div>
      </div>

      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        <a
          href="/dashboard/clients"
          class="shell-card group flex items-center justify-between p-5 transition hover:-translate-y-0.5 hover:shadow-lg"
        >
          <div>
            <p class="eyebrow">Clients</p>
            <p
              id="home-count-clients"
              class="mt-2 text-3xl font-semibold tabular-nums tracking-tight text-stone-950"
            >
              —
            </p>
            <p class="mt-0.5 text-xs text-stone-500">Registered MCP clients</p>
          </div>
          <span
            class="text-stone-300 transition group-hover:text-amber-700"
            aria-hidden="true"
          >
            <svg viewBox="0 0 20 20" fill="currentColor" class="h-6 w-6"
              ><path
                fill-rule="evenodd"
                d="M7.21 14.77a.75.75 0 01.02-1.06L11.168 10 7.23 6.29a.75.75 0 111.04-1.08l4.5 4.25a.75.75 0 010 1.08l-4.5 4.25a.75.75 0 01-1.06-.02z"
                clip-rule="evenodd"></path></svg
            >
          </span>
        </a>

        <a
          href="/dashboard/repositories"
          class="shell-card group flex items-center justify-between p-5 transition hover:-translate-y-0.5 hover:shadow-lg"
        >
          <div>
            <p class="eyebrow">Repositories</p>
            <p
              id="home-count-repos"
              class="mt-2 text-3xl font-semibold tabular-nums tracking-tight text-stone-950"
            >
              —
            </p>
            <p class="mt-0.5 text-xs text-stone-500">Synced code repos</p>
          </div>
          <span
            class="text-stone-300 transition group-hover:text-amber-700"
            aria-hidden="true"
          >
            <svg viewBox="0 0 20 20" fill="currentColor" class="h-6 w-6"
              ><path
                fill-rule="evenodd"
                d="M7.21 14.77a.75.75 0 01.02-1.06L11.168 10 7.23 6.29a.75.75 0 111.04-1.08l4.5 4.25a.75.75 0 010 1.08l-4.5 4.25a.75.75 0 01-1.06-.02z"
                clip-rule="evenodd"></path></svg
            >
          </span>
        </a>

        <a
          href="/dashboard/workflows"
          class="shell-card group flex items-center justify-between p-5 transition hover:-translate-y-0.5 hover:shadow-lg"
        >
          <div>
            <p class="eyebrow">Workflows</p>
            <p
              id="home-count-workflows"
              class="mt-2 text-3xl font-semibold tabular-nums tracking-tight text-stone-950"
            >
              —
            </p>
            <p class="mt-0.5 text-xs text-stone-500">Enforcement pipelines</p>
          </div>
          <span
            class="text-stone-300 transition group-hover:text-amber-700"
            aria-hidden="true"
          >
            <svg viewBox="0 0 20 20" fill="currentColor" class="h-6 w-6"
              ><path
                fill-rule="evenodd"
                d="M7.21 14.77a.75.75 0 01.02-1.06L11.168 10 7.23 6.29a.75.75 0 111.04-1.08l4.5 4.25a.75.75 0 010 1.08l-4.5 4.25a.75.75 0 01-1.06-.02z"
                clip-rule="evenodd"></path></svg
            >
          </span>
        </a>

        <a
          href="/dashboard/users"
          class="shell-card group flex items-center justify-between p-5 transition hover:-translate-y-0.5 hover:shadow-lg"
        >
          <div>
            <p class="eyebrow">Users</p>
            <p
              id="home-count-users"
              class="mt-2 text-3xl font-semibold tabular-nums tracking-tight text-stone-950"
            >
              —
            </p>
            <p
              id="home-count-users-sub"
              class="mt-0.5 text-xs text-stone-500"
            >
              Admin + operator accounts
            </p>
          </div>
          <span
            class="text-stone-300 transition group-hover:text-amber-700"
            aria-hidden="true"
          >
            <svg viewBox="0 0 20 20" fill="currentColor" class="h-6 w-6"
              ><path
                fill-rule="evenodd"
                d="M7.21 14.77a.75.75 0 01.02-1.06L11.168 10 7.23 6.29a.75.75 0 111.04-1.08l4.5 4.25a.75.75 0 010 1.08l-4.5 4.25a.75.75 0 01-1.06-.02z"
                clip-rule="evenodd"></path></svg
            >
          </span>
        </a>
      </div>
    </section>

    <!-- ── Usage metrics ── -->
    <section>
      <div class="mb-3 flex items-end justify-between">
        <div>
          <p class="eyebrow">Usage</p>
          <h2 class="mt-1 text-xl font-semibold tracking-tight text-stone-950">
            Live counters (since process start)
          </h2>
        </div>
        <a
          href="/dashboard/observability"
          class="text-sm font-medium text-amber-800 hover:text-amber-900"
        >
          Open observability →
        </a>
      </div>

      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        <div class="shell-card p-5">
          <p class="eyebrow">Active sessions</p>
          <p
            id="home-sessions"
            class="mt-2 text-3xl font-semibold tabular-nums tracking-tight text-stone-950"
          >
            —
          </p>
          <p class="mt-0.5 text-xs text-stone-500">Client sessions right now</p>
        </div>

        <div class="shell-card p-5">
          <p class="eyebrow">Tool calls</p>
          <p
            id="home-tool-calls"
            class="mt-2 text-3xl font-semibold tabular-nums tracking-tight text-stone-950"
          >
            —
          </p>
          <p
            id="home-tool-calls-sub"
            class="mt-0.5 text-xs text-stone-500"
          >
            —
          </p>
        </div>

        <div class="shell-card p-5">
          <p class="eyebrow">HTTP requests</p>
          <p
            id="home-http"
            class="mt-2 text-3xl font-semibold tabular-nums tracking-tight text-stone-950"
          >
            —
          </p>
          <p id="home-http-sub" class="mt-0.5 text-xs text-stone-500">
            —
          </p>
        </div>

        <div class="shell-card p-5">
          <p class="eyebrow">Auth events</p>
          <p
            id="home-auth"
            class="mt-2 text-3xl font-semibold tabular-nums tracking-tight text-stone-950"
          >
            —
          </p>
          <p id="home-auth-sub" class="mt-0.5 text-xs text-stone-500">
            —
          </p>
        </div>
      </div>
    </section>

    <!-- ── Recent activity ── -->
    <section>
      <div class="mb-3 flex items-end justify-between">
        <div>
          <p class="eyebrow">Recent activity</p>
          <h2 class="mt-1 text-xl font-semibold tracking-tight text-stone-950">
            Last 8 audit events
          </h2>
        </div>
        <a
          href="/dashboard/observability"
          class="text-sm font-medium text-amber-800 hover:text-amber-900"
        >
          Full audit log →
        </a>
      </div>

      <div
        class="shell-card overflow-hidden"
        id="home-recent-wrap"
      >
        <table class="w-full text-sm">
          <thead>
            <tr
              class="border-b border-stone-200 bg-stone-50/80 text-left text-[11px] font-semibold uppercase tracking-widest text-stone-500"
            >
              <th class="px-5 py-3">Event</th>
              <th class="px-5 py-3">Actor</th>
              <th class="px-5 py-3">Resource</th>
              <th class="px-5 py-3">Outcome</th>
              <th class="px-5 py-3 whitespace-nowrap">When</th>
            </tr>
          </thead>
          <tbody id="home-recent-body">
            <tr>
              <td
                colspan="5"
                class="px-5 py-8 text-center text-sm text-stone-400"
                >Loading recent activity…</td
              >
            </tr>
          </tbody>
        </table>
      </div>
    </section>
  </div>

  <script src="../scripts/dashboard-home.ts"></script>
</DashboardLayout>
