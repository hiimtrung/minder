---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  navTitle?: string;
  navDescription?: string;
  navLinks?: Array<{ href: string; label: string; tone?: "primary" | "secondary" }>;
  sessionControls?: boolean;
}

const {
  title,
  description = "Minder dashboard shell",
  navTitle = "Minder Console",
  navDescription = "Admin setup, login, client management, and onboarding on one port.",
  navLinks = [],
  sessionControls = false,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>
  <body>
    <div class="min-h-screen">
      <header class="mx-auto max-w-6xl px-6 py-6">
        <div class="shell-card flex flex-wrap items-center justify-between gap-4 px-5 py-4">
          <div class="space-y-1">
            <a href="/dashboard" class="text-lg font-semibold tracking-tight text-stone-900">{navTitle}</a>
            <p class="text-sm text-stone-600">{navDescription}</p>
          </div>
          <div class="flex flex-wrap items-center gap-3">
            {sessionControls && (
              <div class="flex items-center gap-2">
                <span
                  id="dashboard-session-badge"
                  class="inline-flex items-center rounded-full border border-emerald-200 bg-emerald-50 px-3 py-1 text-xs font-semibold tracking-[0.18em] text-emerald-800 uppercase"
                >
                  Checking Session
                </span>
                <button id="dashboard-logout-button" type="button" class="action-pill">
                  Logout
                </button>
              </div>
            )}
            <nav class="flex flex-wrap items-center gap-2 text-sm">
              {navLinks.map((link) => (
                <a href={link.href} class={link.tone === "primary" ? "primary-pill" : "action-pill"}>
                  {link.label}
                </a>
              ))}
            </nav>
          </div>
        </div>
      </header>
      <main class="mx-auto max-w-6xl px-6 pb-16">
        <slot />
      </main>
      <div id="dashboard-toast-region" class="pointer-events-none fixed right-6 bottom-6 z-50 flex max-w-sm flex-col gap-3"></div>
    </div>
    {sessionControls && <script src="../scripts/session-header.ts"></script>}
  </body>
</html>
