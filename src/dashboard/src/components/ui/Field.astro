---
/**
 * Field — label + control wrapper.
 * Use the default slot for the actual input/textarea/select element.
 * Pass hint via prop or named slot; error via slot.
 */
interface Props {
  label?: string;
  htmlFor?: string;
  hint?: string;
  class?: string;
}

const { label, htmlFor, hint, class: className = "" } = Astro.props;
---

<label class={`block ${className}`} for={htmlFor}>
  {label && <span class="u-field-label">{label}</span>}
  <slot />
  {
    (hint || Astro.slots.has("hint")) && (
      <span class="u-field-hint">
        {hint}
        <slot name="hint" />
      </span>
    )
  }
  {
    Astro.slots.has("error") && (
      <span class="u-field-error">
        <slot name="error" />
      </span>
    )
  }
</label>
