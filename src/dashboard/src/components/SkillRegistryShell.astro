---
import DashboardLayout from "../layouts/DashboardLayout.astro";
import PageHero from "./ui/PageHero.astro";
import Toolbar from "./ui/Toolbar.astro";
import Field from "./ui/Field.astro";
import Input from "./ui/Input.astro";
import Select from "./ui/Select.astro";
import Textarea from "./ui/Textarea.astro";
import Button from "./ui/Button.astro";
import FormStatus from "./ui/FormStatus.astro";
import GuideAside from "./ui/GuideAside.astro";
---

<DashboardLayout
  title="Skills · Minder"
  description="Ingest, curate, and manage reusable workflow-aware skills for the Minder runtime."
  navTitle="Minder Dashboard"
  navDescription="Create, ingest, and maintain workflow-aware skills that can be recalled by the continuity layer at runtime."
  sessionControls={true}
  showPageIntro={false}
>
  <PageHero
    eyebrow="Skill Registry"
    title="Ingest and manage skills."
    description="Capture reusable workflow knowledge with step tags, artifact tags, provenance, and quality signals so the runtime can recall better context."
  />

  <section class="u-grid-sidebar">
    <div class="grid gap-5">
      <aside class="shell-card p-6">
        <div class="flex items-center justify-between gap-3">
          <div>
            <p class="eyebrow">Editor</p>
            <h2
              class="font-display mt-2 text-xl font-semibold tracking-tight text-stone-950"
            >
              Skill draft
            </h2>
          </div>
          <Button id="skill-reset-button" size="sm" variant="ghost">
            New draft
          </Button>
        </div>

        <form id="skill-form" class="mt-5 grid gap-4">
          <input id="skill-id" type="hidden" />
          <Field label="Title" htmlFor="skill-title">
            <Input id="skill-title" placeholder="Test plan drafting pattern" />
          </Field>
          <Field label="Language" htmlFor="skill-language">
            <Input
              id="skill-language"
              placeholder="markdown"
              value="markdown"
            />
          </Field>
          <Field label="Tags" htmlFor="skill-tags">
            <Input id="skill-tags" placeholder="tdd, regression, continuity" />
          </Field>
          <Field label="Workflow steps" htmlFor="skill-workflow-steps">
            <Input
              id="skill-workflow-steps"
              placeholder="Test Writing, Implementation"
            />
          </Field>
          <Field label="Artifact types" htmlFor="skill-artifact-types">
            <Input
              id="skill-artifact-types"
              placeholder="test_plan, implementation_notes"
            />
          </Field>

          <div class="grid gap-4 sm:grid-cols-2">
            <Field label="Provenance" htmlFor="skill-provenance">
              <Input id="skill-provenance" placeholder="dashboard_manual" />
            </Field>
            <Field label="Excerpt kind" htmlFor="skill-excerpt-kind">
              <Select id="skill-excerpt-kind">
                <option value="none">none</option>
                <option value="reusable_excerpt">reusable_excerpt</option>
              </Select>
            </Field>
          </div>

          <Field label="Quality score" htmlFor="skill-quality-score">
            <Input
              id="skill-quality-score"
              type="number"
              min={0}
              max={1}
              step={0.1}
              value={0.7}
            />
          </Field>

          <div
            id="skill-source-summary"
            class="hidden rounded-2xl border border-stone-200 bg-stone-50 px-4 py-3 text-sm text-stone-600 truncate"
          >
          </div>

          <Field
            label="Skill content"
            htmlFor="skill-content"
            hint="Saving this form ingests the skill into the continuity store."
          >
            <Textarea
              id="skill-content"
              variant="large"
              placeholder="Describe the reusable workflow pattern, expected artifacts, and common pitfalls."
            />
          </Field>

          <div class="flex flex-wrap gap-3">
            <Button
              type="submit"
              variant="primary"
              class="flex-1 min-w-[180px]"
            >
              Save and ingest skill
            </Button>
          </div>
          <FormStatus id="skill-editor-status" />
        </form>
      </aside>
    </div>

    <div class="flex flex-col gap-5">
      <div
        id="skill-import-job-summary"
        class="hidden rounded-3xl border border-amber-200 bg-amber-50/80 px-5 py-4 text-sm text-amber-900"
      >
      </div>

      <Toolbar
        idPrefix="skill"
        title="Registry"
        description="Load any skill into the editor, update metadata, or remove stale entries from the recall catalog."
        searchPlaceholder="Semantic quick search skills"
      >
        <Button slot="leading" id="skill-refresh-button" size="sm">
          Refresh list
        </Button>
        <Button
          slot="leading"
          id="skill-open-import-modal"
          size="sm"
          variant="primary"
        >
          Import from Git
        </Button>
      </Toolbar>

      <section class="grid gap-5 2xl:grid-cols-[minmax(0,1fr)_340px]">
        <div id="skill-registry" class="grid gap-4">
          <article class="u-placeholder-card">Loading skills...</article>
        </div>

        <GuideAside eyebrow="Ingest Guide" title="What makes a good skill">
          <p>
            Write a single reusable pattern per skill. Keep it operational and
            specific to a workflow step or artifact outcome.
          </p>
          <p>
            Use workflow steps to guide recall ranking, artifact types to bind
            the skill to expected outputs, and provenance to show where it came
            from.
          </p>
          <p>
            Quality score is a soft confidence signal. Higher values push the
            skill up when semantic similarity is close.
          </p>
          <p>
            Imported skill packs upsert by source metadata so rerunning an
            import updates the same skill set instead of multiplying duplicates.
          </p>
        </GuideAside>
      </section>
    </div>
  </section>

  <dialog
    id="skill-import-modal"
    class="m-auto w-[min(980px,calc(100vw-1.5rem))] max-w-[980px] max-h-[min(90vh,920px)] overflow-hidden rounded-[28px] border border-stone-200/80 bg-[rgba(255,252,245,0.99)] p-0 text-stone-900 shadow-[0_40px_120px_rgba(28,25,23,0.25)] backdrop:bg-stone-950/50 backdrop:backdrop-blur-sm"
  >
    <div class="grid min-h-0 max-h-[min(90vh,920px)] lg:grid-cols-[minmax(0,1fr)_340px]">

      <!-- LEFT: Form -->
      <section class="flex min-h-0 flex-col overflow-hidden">
        <!-- Modal header -->
        <div class="flex shrink-0 items-start justify-between gap-4 border-b border-stone-100 px-7 pt-7 pb-6">
          <div>
            <p class="eyebrow">Git Import</p>
            <h2 class="mt-2 text-2xl font-semibold tracking-tight text-stone-950">
              Import skill pack
            </h2>
            <p class="mt-1.5 max-w-xs text-sm leading-relaxed text-stone-500">
              Pull a skill pack from any Git host. The job runs in the background — you can close this modal and check progress in Observability.
            </p>
          </div>
          <Button id="skill-close-import-modal" size="sm" variant="ghost" ariaLabel="Close modal">
            ✕
          </Button>
        </div>

        <!-- Scrollable form body -->
        <form id="skill-import-form" class="flex min-h-0 flex-1 flex-col overflow-y-auto px-7 py-6">
          <div class="grid gap-4">
            <Field label="Repository URL" htmlFor="skill-import-repo-url">
              <Input
                id="skill-import-repo-url"
                type="url"
                placeholder="https://github.com/org/skills.git"
              />
            </Field>

            <div class="grid gap-3 sm:grid-cols-[1fr_8rem]">
              <Field label="Skills path" htmlFor="skill-import-path" hint="Folder inside the repo">
                <Input id="skill-import-path" value="skills" placeholder="skills" />
              </Field>
              <Field label="Ref" htmlFor="skill-import-ref" hint="Branch / tag">
                <Input id="skill-import-ref" placeholder="main" />
              </Field>
            </div>

            <div class="grid gap-3 sm:grid-cols-2">
              <Field label="Provider" htmlFor="skill-import-provider">
                <Select id="skill-import-provider">
                  <option value="">Auto-detect</option>
                  <option value="github">GitHub</option>
                  <option value="gitlab">GitLab</option>
                  <option value="generic_git">Generic Git</option>
                </Select>
              </Field>
              <Field label="Excerpt kind" htmlFor="skill-import-excerpt-kind">
                <Select id="skill-import-excerpt-kind">
                  <option value="none">none</option>
                  <option value="reusable_excerpt">reusable_excerpt</option>
                </Select>
              </Field>
            </div>
          </div>

          <!-- Active job progress (rendered by JS) -->
          <div
            id="skill-import-active-job"
            class="hidden mt-5 rounded-2xl border border-stone-200 bg-stone-50/80 px-5 py-4"
          ></div>

          <!-- Spacer pushes submit to bottom -->
          <div class="flex-1 min-h-6"></div>

          <!-- Submit row -->
          <div class="mt-4 flex flex-wrap items-center gap-3 border-t border-stone-100 pt-5">
            <Button type="submit" variant="primary" class="flex-1 min-w-[180px]">
              Queue import job
            </Button>
            <Button
              id="skill-open-observability"
              href="/dashboard/observability"
              size="sm"
              variant="ghost"
            >
              Observability →
            </Button>
          </div>
          <FormStatus id="skill-import-status" />
        </form>
      </section>

      <!-- RIGHT: Dark sidebar -->
      <aside class="flex min-h-0 flex-col overflow-hidden border-t border-stone-200 bg-stone-950 text-stone-100 lg:border-l lg:border-t-0">

        <!-- Progress log (rendered by JS, hidden until job has events) -->
        <div
          id="skill-import-progress-log"
          class="hidden shrink-0 overflow-y-auto border-b border-stone-800/60 px-5 py-4 font-mono text-[11px] leading-5 max-h-44"
        ></div>

        <!-- Recent jobs list -->
        <div class="flex min-h-0 flex-1 flex-col overflow-hidden px-5 py-5">
          <p class="eyebrow shrink-0 text-stone-400">Recent jobs</p>
          <p class="mt-1 shrink-0 text-xs leading-5 text-stone-500">
            Jobs persist across page reloads.
          </p>
          <div
            id="skill-import-job-list"
            class="mt-4 flex-1 overflow-y-auto grid gap-2 content-start"
          >
            <div class="rounded-2xl border border-stone-800 bg-stone-900/70 px-4 py-3 text-sm text-stone-400">
              No import jobs yet.
            </div>
          </div>
        </div>
      </aside>

    </div>
  </dialog>

  <script src="../scripts/skills-page.ts"></script>
</DashboardLayout>
