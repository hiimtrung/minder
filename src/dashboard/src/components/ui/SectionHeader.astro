---
/**
 * SectionHeader — smaller than PageHero, used between content sections.
 */
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  class?: string;
}

const { eyebrow, title, description, class: className = "" } = Astro.props;
---

<div class={`u-section-header ${className}`}>
  <div>
    {eyebrow && <p class="eyebrow">{eyebrow}</p>}
    <h2 class="u-section-header-title mt-1">{title}</h2>
    {description && <p class="mt-1 text-sm text-stone-600">{description}</p>}
  </div>
  {
    Astro.slots.has("actions") && (
      <div class="flex flex-wrap items-center gap-2">
        <slot name="actions" />
      </div>
    )
  }
</div>
