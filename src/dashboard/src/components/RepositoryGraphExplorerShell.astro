---
import DashboardLayout from "../layouts/DashboardLayout.astro";
---

<DashboardLayout
  title="Repositories · Minder"
  description="Repository graph explorer for Minder dashboard."
  navTitle="Minder Dashboard"
  navDescription="Inspect synced repository graph state, edit repository metadata, and explore structural impact from the admin dashboard."
  sessionControls={true}
  showPageIntro={false}
>
  <section class="mb-8 flex flex-wrap items-end justify-between gap-4">
    <div class="space-y-3">
      <p class="eyebrow">Repository Explorer</p>
      <h1 class="text-5xl font-semibold tracking-tight text-stone-950">
        Browse the synced repository graph.
      </h1>
      <p class="max-w-3xl text-lg leading-8 text-stone-700">
        Choose a repository and Minder renders the current node graph first.
        Search and impact analysis stay available below, but the page now opens
        on the repository canvas itself.
      </p>
    </div>
  </section>

  <section class="grid gap-8 lg:grid-cols-[320px_minmax(0,1fr)]">
    <aside class="shell-card p-7">
      <div class="flex items-center justify-between gap-3">
        <div>
          <p class="eyebrow">Repositories</p>
          <h2 class="mt-3 text-2xl font-semibold tracking-tight text-stone-950">
            Select a synced repo
          </h2>
        </div>
        <button
          id="repositories-refresh"
          type="button"
          class="action-pill text-xs"
        >
          Refresh
        </button>
      </div>
      <p class="mt-3 text-sm leading-6 text-stone-600">
        Each card opens the repository graph canvas and the editable repository
        settings panel.
      </p>
      <div id="repositories-status" class="mt-4 min-h-6 text-sm text-stone-600">
      </div>
      <div id="repositories-list" class="mt-4 grid gap-3">
        <article
          class="rounded-3xl border border-stone-200 bg-stone-50 px-4 py-4 text-sm text-stone-600"
        >
          Loading repositories...
        </article>
      </div>
    </aside>

    <div class="grid gap-6">
      <section class="shell-card p-7">
        <div class="flex flex-wrap items-start justify-between gap-4">
          <div>
            <p class="eyebrow">Repository Overview</p>
            <h2
              id="repo-summary-title"
              class="mt-3 text-3xl font-semibold tracking-tight text-stone-950"
            >
              Select a repository
            </h2>
            <p id="repo-summary-meta" class="mt-2 text-sm text-stone-600">
              No repository selected.
            </p>
          </div>
          <div class="flex items-center gap-3">
            <button
              id="repo-graph-refresh"
              type="button"
              class="action-pill text-xs"
            >
              Reload Graph
            </button>
            <div
              id="repo-summary-sync"
              class="rounded-full border border-stone-200 bg-stone-50 px-4 py-2 text-xs font-semibold uppercase tracking-[0.22em] text-stone-600"
            >
              Waiting
            </div>
          </div>
        </div>

        <div id="repo-summary-cards" class="mt-6 grid gap-4 md:grid-cols-4">
          <article
            class="rounded-3xl border border-stone-200 bg-stone-50 px-5 py-4 text-sm text-stone-600"
          >
            Graph metrics will appear here after selection.
          </article>
        </div>

        <div class="mt-6 grid gap-4 xl:grid-cols-2">
          <article class="rounded-3xl border border-stone-200 bg-stone-50 p-5">
            <p class="eyebrow">Routes</p>
            <div
              id="repo-routes"
              class="mt-4 grid gap-3 text-sm text-stone-700"
            >
            </div>
          </article>
          <article class="rounded-3xl border border-stone-200 bg-stone-50 p-5">
            <p class="eyebrow">TODOs</p>
            <div id="repo-todos" class="mt-4 grid gap-3 text-sm text-stone-700">
            </div>
          </article>
          <article class="rounded-3xl border border-stone-200 bg-stone-50 p-5">
            <p class="eyebrow">External Services</p>
            <div
              id="repo-services"
              class="mt-4 grid gap-3 text-sm text-stone-700"
            >
            </div>
          </article>
          <article class="rounded-3xl border border-stone-200 bg-stone-50 p-5">
            <p class="eyebrow">Service Dependencies</p>
            <div
              id="repo-dependencies"
              class="mt-4 grid gap-3 text-sm text-stone-700"
            >
            </div>
          </article>
        </div>
      </section>

      <section class="grid gap-6 xl:grid-cols-[minmax(0,1.5fr)_380px]">
        <article class="shell-card p-7">
          <div class="flex flex-wrap items-start justify-between gap-4">
            <div>
              <p class="eyebrow">Repository Graph</p>
              <h2
                class="mt-3 text-2xl font-semibold tracking-tight text-stone-950"
              >
                Full graph canvas
              </h2>
              <p class="mt-3 max-w-2xl text-sm leading-6 text-stone-600">
                This is the primary view now: folders, files, and symbols render
                immediately from the synced graph snapshot for the selected
                repository.
              </p>
            </div>
            <p id="repo-graph-status" class="min-h-6 text-sm text-stone-600">
            </p>
          </div>

          <div id="repo-graph-summary" class="mt-5 grid gap-3 md:grid-cols-4">
          </div>
          <div class="mt-5 grid gap-4 xl:grid-cols-[minmax(0,1.35fr)_280px]">
            <div
              class="overflow-hidden rounded-[2rem] border border-stone-200 bg-[radial-gradient(circle_at_top,_rgba(16,185,129,0.16),_transparent_40%),linear-gradient(180deg,_#fcfff9_0%,_#eef6f1_100%)] p-3 shadow-[inset_0_1px_0_rgba(255,255,255,0.8)]"
            >
              <canvas
                id="repo-graph-canvas"
                class="block h-[520px] w-full rounded-[1.5rem]"></canvas>
            </div>
            <div class="grid gap-4">
              <div
                id="repo-graph-legend"
                class="rounded-[2rem] border border-stone-200 bg-stone-50 p-4"
              >
              </div>
              <div
                id="repo-graph-details"
                class="rounded-[2rem] border border-stone-200 bg-white p-4"
              >
              </div>
            </div>
          </div>
        </article>

        <article class="shell-card p-7">
          <p class="eyebrow">Repository Settings</p>
          <h2 class="mt-3 text-2xl font-semibold tracking-tight text-stone-950">
            Edit or delete this repo
          </h2>
          <p class="mt-3 text-sm leading-6 text-stone-600">
            Update the repository name, remote, default branch, or stored path.
            Delete removes the repository record from the dashboard list.
          </p>
          <form id="repo-settings-form" class="mt-6 grid gap-4">
            <label class="grid gap-2 text-sm text-stone-700">
              <span>Name</span>
              <input
                id="repo-settings-name"
                class="rounded-2xl border border-stone-300 bg-white px-4 py-3"
              />
            </label>
            <label class="grid gap-2 text-sm text-stone-700">
              <span>Remote URL</span>
              <input
                id="repo-settings-remote"
                class="rounded-2xl border border-stone-300 bg-white px-4 py-3"
              />
            </label>
            <label class="grid gap-2 text-sm text-stone-700">
              <span>Default Branch</span>
              <input
                id="repo-settings-branch"
                class="rounded-2xl border border-stone-300 bg-white px-4 py-3"
              />
            </label>
            <label class="grid gap-2 text-sm text-stone-700">
              <span>State Path</span>
              <input
                id="repo-settings-path"
                class="rounded-2xl border border-stone-300 bg-white px-4 py-3"
              />
            </label>
            <p id="repo-settings-status" class="min-h-6 text-sm text-stone-600">
            </p>
            <div class="flex flex-wrap gap-3">
              <button type="submit" class="primary-pill">Save Changes</button>
              <button
                id="repo-settings-delete"
                type="button"
                class="action-pill border-red-300 bg-red-50 text-red-700"
              >
                Delete Repository
              </button>
            </div>
          </form>
        </article>
      </section>

      <section class="grid gap-6 xl:grid-cols-2">
        <article class="shell-card p-7">
          <p class="eyebrow">Search Graph</p>
          <h2 class="mt-3 text-2xl font-semibold tracking-tight text-stone-950">
            Focus the current graph
          </h2>
          <p class="mt-3 max-w-2xl text-sm leading-6 text-stone-600">
            Search stays here as a secondary tool when you need to isolate a
            route, file, symbol, language, or last git state.
          </p>
          <form id="graph-search-form" class="mt-6 grid gap-4">
            <input
              id="graph-search-query"
              class="rounded-2xl border border-stone-300 bg-white px-4 py-3"
              placeholder="Search for route path, file, symbol, or text"
            />
            <div class="grid gap-4 lg:grid-cols-3">
              <input
                id="graph-search-types"
                class="rounded-2xl border border-stone-300 bg-white px-4 py-3"
                placeholder="Optional node types, comma-separated"
              />
              <input
                id="graph-search-languages"
                class="rounded-2xl border border-stone-300 bg-white px-4 py-3"
                placeholder="Languages, comma-separated"
              />
              <input
                id="graph-search-states"
                class="rounded-2xl border border-stone-300 bg-white px-4 py-3"
                placeholder="States, e.g. modified, clean"
              />
            </div>
            <div class="flex items-center justify-between gap-3">
              <p
                id="graph-search-status"
                class="min-h-6 text-sm text-stone-600"
              >
              </p>
              <button type="submit" class="primary-pill">Search</button>
            </div>
          </form>
          <div class="mt-5 grid gap-4 xl:grid-cols-[minmax(0,1.35fr)_280px]">
            <div
              class="overflow-hidden rounded-[2rem] border border-stone-200 bg-[radial-gradient(circle_at_top,_rgba(245,158,11,0.18),_transparent_42%),linear-gradient(180deg,_#fffdf7_0%,_#f6f3ee_100%)] p-3 shadow-[inset_0_1px_0_rgba(255,255,255,0.8)]"
            >
              <canvas
                id="graph-search-canvas"
                class="block h-[420px] w-full rounded-[1.5rem]"></canvas>
            </div>
            <div class="grid gap-4">
              <div
                id="graph-search-legend"
                class="rounded-[2rem] border border-stone-200 bg-stone-50 p-4"
              >
              </div>
              <div
                id="graph-search-details"
                class="rounded-[2rem] border border-stone-200 bg-white p-4"
              >
              </div>
            </div>
          </div>
        </article>

        <article class="shell-card p-7">
          <p class="eyebrow">Impact Scan</p>
          <h2 class="mt-3 text-2xl font-semibold tracking-tight text-stone-950">
            Trace local blast radius
          </h2>
          <p class="mt-3 max-w-2xl text-sm leading-6 text-stone-600">
            Impact view remains available when you want to traverse upstream and
            downstream neighbors from a symbol or route.
          </p>
          <form id="graph-impact-form" class="mt-6 grid gap-4">
            <input
              id="graph-impact-target"
              class="rounded-2xl border border-stone-300 bg-white px-4 py-3"
              placeholder="Target symbol or route"
            />
            <div class="grid gap-4 sm:grid-cols-2">
              <input
                id="graph-impact-depth"
                type="number"
                min="1"
                max="6"
                value="2"
                class="rounded-2xl border border-stone-300 bg-white px-4 py-3"
              />
              <input
                id="graph-impact-limit"
                type="number"
                min="1"
                max="100"
                value="25"
                class="rounded-2xl border border-stone-300 bg-white px-4 py-3"
              />
            </div>
            <div class="flex items-center justify-between gap-3">
              <p
                id="graph-impact-status"
                class="min-h-6 text-sm text-stone-600"
              >
              </p>
              <button type="submit" class="primary-pill">Analyze</button>
            </div>
          </form>
          <div id="graph-impact-summary" class="mt-5 grid gap-3"></div>
          <div class="mt-4 grid gap-4 xl:grid-cols-[minmax(0,1.35fr)_280px]">
            <div
              class="overflow-hidden rounded-[2rem] border border-stone-200 bg-[radial-gradient(circle_at_top,_rgba(14,165,233,0.18),_transparent_44%),linear-gradient(180deg,_#f8fdff_0%,_#eef4f7_100%)] p-3 shadow-[inset_0_1px_0_rgba(255,255,255,0.8)]"
            >
              <canvas
                id="graph-impact-canvas"
                class="block h-[420px] w-full rounded-[1.5rem]"></canvas>
            </div>
            <div class="grid gap-4">
              <div
                id="graph-impact-legend"
                class="rounded-[2rem] border border-stone-200 bg-stone-50 p-4"
              >
              </div>
              <div
                id="graph-impact-details"
                class="rounded-[2rem] border border-stone-200 bg-white p-4"
              >
              </div>
            </div>
          </div>
        </article>
      </section>
    </div>
  </section>

  <script src="../scripts/repositories-page.ts"></script>
</DashboardLayout>
