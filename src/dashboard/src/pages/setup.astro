---
import DashboardLayout from "../layouts/DashboardLayout.astro";
---

<DashboardLayout
  title="Initial Setup · Minder"
  description="Initial setup shell for the Astro-based Minder dashboard."
  navTitle="Minder Setup"
  navDescription="Create the first admin account, then store the bootstrap key safely."
  navLinks={[
    { href: "/dashboard/login", label: "Admin Login", tone: "secondary" },
  ]}
  showPageIntro={false}
>
  <section class="grid gap-8 lg:grid-cols-[0.95fr_1.05fr] lg:items-start">
    <div class="shell-card p-8">
      <p class="eyebrow">First-Run Setup</p>
      <h1 class="mt-3 text-4xl font-semibold tracking-tight text-stone-950">
        Create the first Minder admin
      </h1>
      <p class="mt-4 text-base leading-7 text-stone-700">
        This is the browser-first bootstrap flow for a fresh Minder deployment.
        It creates the first admin and reveals the bootstrap API key exactly
        once.
      </p>
      <ul class="mt-6 space-y-3 text-sm leading-6 text-stone-700">
        <li>Creates the first admin only when no admin exists yet.</li>
        <li>
          Set a password here so you can sign in with
          <strong>username&nbsp;+ password</strong> going forward.
        </li>
        <li>Reveals the bootstrap API key exactly once after creation.</li>
        <li>
          Redirects future visits back to the login flow once setup is complete.
        </li>
      </ul>
    </div>

    <div class="shell-card p-8">
      <form id="setup-form" class="grid gap-5">
        <label class="block">
          <span class="mb-2 block text-sm font-medium text-stone-800"
            >Username</span
          >
          <input
            id="setup-username"
            class="w-full rounded-2xl border border-stone-300 bg-white px-4 py-3"
            placeholder="admin"
          />
        </label>
        <label class="block">
          <span class="mb-2 block text-sm font-medium text-stone-800"
            >Email</span
          >
          <input
            id="setup-email"
            type="email"
            class="w-full rounded-2xl border border-stone-300 bg-white px-4 py-3"
            placeholder="admin@example.com"
          />
        </label>
        <label class="block">
          <span class="mb-2 block text-sm font-medium text-stone-800"
            >Display name</span
          >
          <input
            id="setup-display-name"
            class="w-full rounded-2xl border border-stone-300 bg-white px-4 py-3"
            placeholder="Platform Admin"
          />
        </label>
        <label class="block">
          <span class="mb-2 block text-sm font-medium text-stone-800"
            >Password</span
          >
          <input
            id="setup-password"
            type="password"
            class="w-full rounded-2xl border border-stone-300 bg-white px-4 py-3"
            placeholder="Min. 8 characters"
          />
        </label>
        <label class="block">
          <span class="mb-2 block text-sm font-medium text-stone-800"
            >Confirm password</span
          >
          <input
            id="setup-password-confirm"
            type="password"
            class="w-full rounded-2xl border border-stone-300 bg-white px-4 py-3"
            placeholder="Repeat password"
          />
        </label>
        <p id="setup-status" class="min-h-6 text-sm text-stone-600"></p>
        <button type="submit" class="primary-pill w-full"
          >Create initial admin</button
        >
      </form>
      <div
        id="setup-result"
        class="mt-6 hidden rounded-3xl border border-amber-200 bg-amber-50 p-4"
      >
        <p class="eyebrow">Bootstrap API Key</p>
        <p class="mt-2 text-sm text-stone-600">
          You can also sign in with your username + password. Keep this key as a
          recovery fallback.
        </p>
        <code
          id="setup-api-key"
          class="mt-3 block overflow-x-auto rounded-2xl bg-white px-4 py-3 text-sm text-stone-800"
        ></code>
        <a
          href="/dashboard/login"
          class="primary-pill mt-5 block w-full text-center"
        >
          Go to login →
        </a>
      </div>
    </div>
  </section>
  <script src="../scripts/setup-page.ts"></script>
</DashboardLayout>
