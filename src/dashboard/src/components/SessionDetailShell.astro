---
import DashboardLayout from "../layouts/DashboardLayout.astro";
import DetailHeader from "./ui/DetailHeader.astro";
import Card from "./ui/Card.astro";
import Button from "./ui/Button.astro";

interface Props {
  sessionId?: string;
}

const { sessionId = "" } = Astro.props;
---

<DashboardLayout
  title="Session Detail · Minder"
  description="Dedicated Astro shell for Minder session detail and continuity inspection."
  navTitle="Minder Dashboard"
  navDescription="Inspect runtime continuity, project context, and skill states for a specific session."
  sessionControls={true}
  showPageIntro={false}
>
  <DetailHeader
    breadcrumb={[
      { href: "/dashboard", label: "Dashboard" },
      { href: "/dashboard/sessions", label: "Sessions" },
      { label: "Session Detail" },
    ]}
    eyebrow="Session Detail"
    title="Loading session..."
    titleId="detail-title"
    description="Inspect and manage runtime continuity state. Review active skills, project context, and state memory for this dedicated session."
  >
    <Button slot="actions" id="refresh-session" size="sm" variant="ghost">
      Refresh
    </Button>
    <Button slot="actions" href="/dashboard/sessions" size="sm">
      Back to registry
    </Button>
  </DetailHeader>

  <section id="session-detail-shell" class="u-grid-sidebar">
    <aside class="space-y-5">
      <Card padding="lg">
        <p class="eyebrow">Controls</p>
        <h2 class="font-display mt-2 text-xl font-semibold tracking-tight text-stone-950">
          Session Lifecycle
        </h2>
        <div class="mt-5 grid gap-3">
          <Button id="delete-session" fullWidth variant="ghost">
            Delete session
          </Button>
        </div>
      </Card>

      <Card padding="lg">
        <p class="eyebrow">Metadata</p>
        <h2 class="font-display mt-2 text-xl font-semibold tracking-tight text-stone-950">
          Core Identity
        </h2>
        <dl class="mt-5 space-y-4 text-sm">
          <div>
            <dt class="font-medium text-stone-900">Session ID</dt>
            <dd id="session-id-val" class="mt-1 break-all font-mono text-stone-600"></dd>
          </div>
          <div>
            <dt class="font-medium text-stone-900">Name</dt>
            <dd id="session-name-val" class="mt-1 text-stone-600"></dd>
          </div>
          <div>
            <dt class="font-medium text-stone-900">Client ID</dt>
            <dd id="session-client-id" class="mt-1 font-mono text-stone-600 break-all"></dd>
          </div>
          <div>
            <dt class="font-medium text-stone-900">User ID</dt>
            <dd id="session-user-id" class="mt-1 font-mono text-stone-600 break-all"></dd>
          </div>
          <div>
            <dt class="font-medium text-stone-900">Created At</dt>
            <dd id="session-created-at" class="mt-1 text-stone-600"></dd>
          </div>
          <div>
            <dt class="font-medium text-stone-900">Last Active</dt>
            <dd id="session-last-active" class="mt-1 text-stone-600"></dd>
          </div>
        </dl>
      </Card>
    </aside>

    <div class="grid gap-5">
      <!-- Project Context -->
      <Card padding="lg">
        <div class="flex items-start justify-between gap-3">
          <div>
            <p class="eyebrow">Runtime State</p>
            <h2 class="font-display mt-2 text-xl font-semibold tracking-tight text-stone-950">
              Project Context
            </h2>
          </div>
        </div>
        <div id="project-context-body" class="mt-5"></div>
      </Card>

      <!-- General State — editable -->
      <Card padding="lg">
        <div class="flex items-start justify-between gap-3">
          <div>
            <p class="eyebrow">Memory</p>
            <h2 class="font-display mt-2 text-xl font-semibold tracking-tight text-stone-950">
              General State
            </h2>
          </div>
          <button
            id="toggle-state-edit"
            class="mt-2 rounded-lg border border-stone-200 bg-stone-50 px-3 py-1 text-xs font-medium text-stone-600 transition hover:bg-stone-100"
          >Edit</button>
        </div>

        <!-- Read view -->
        <div id="state-read-view" class="mt-5"></div>

        <!-- Edit form (hidden by default) -->
        <form id="state-edit-form" class="mt-5 hidden space-y-4">
          <div>
            <label class="block text-xs font-medium text-stone-700 mb-1" for="state-task">Task / Phase</label>
            <input
              id="state-task"
              type="text"
              placeholder="Current task or phase description"
              class="w-full rounded-xl border border-stone-200 bg-white px-3 py-2 text-sm text-stone-900 focus:border-amber-400 focus:outline-none"
            />
          </div>
          <div>
            <label class="block text-xs font-medium text-stone-700 mb-1" for="state-next-steps">Next Steps <span class="text-stone-400">(one per line)</span></label>
            <textarea
              id="state-next-steps"
              rows="3"
              placeholder="Next action&#10;Another step"
              class="w-full rounded-xl border border-stone-200 bg-white px-3 py-2 text-sm text-stone-900 focus:border-amber-400 focus:outline-none"
            ></textarea>
          </div>
          <div>
            <label class="block text-xs font-medium text-stone-700 mb-1" for="state-blockers">Blockers <span class="text-stone-400">(one per line)</span></label>
            <textarea
              id="state-blockers"
              rows="2"
              placeholder="Known blocker"
              class="w-full rounded-xl border border-stone-200 bg-white px-3 py-2 text-sm text-stone-900 focus:border-amber-400 focus:outline-none"
            ></textarea>
          </div>
          <div>
            <label class="block text-xs font-medium text-stone-700 mb-1" for="state-extra-json">Additional Fields <span class="text-stone-400">(JSON, optional)</span></label>
            <textarea
              id="state-extra-json"
              rows="3"
              placeholder="{}"
              class="w-full rounded-xl border border-stone-200 bg-white px-3 py-2 font-mono text-xs text-stone-900 focus:border-amber-400 focus:outline-none"
            ></textarea>
          </div>
          <div class="flex items-center gap-3">
            <button
              type="submit"
              class="rounded-xl bg-amber-500 px-4 py-2 text-sm font-semibold text-white transition hover:bg-amber-600"
            >Save state</button>
            <button
              type="button"
              id="cancel-state-edit"
              class="rounded-xl border border-stone-200 bg-white px-4 py-2 text-sm font-medium text-stone-600 transition hover:bg-stone-50"
            >Cancel</button>
            <span id="state-save-status" class="text-xs text-stone-500"></span>
          </div>
        </form>
      </Card>

      <!-- Active Skills -->
      <Card padding="lg">
        <p class="eyebrow">Skills</p>
        <h2 class="font-display mt-2 text-xl font-semibold tracking-tight text-stone-950">
          Active Skill States
        </h2>
        <div id="active-skills-body" class="mt-5"></div>
      </Card>
    </div>
  </section>

  <script src="../scripts/sessions-detail-page.ts"></script>
</DashboardLayout>
