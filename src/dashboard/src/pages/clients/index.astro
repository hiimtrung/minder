---
import DashboardLayout from "../../layouts/DashboardLayout.astro";
---

<DashboardLayout
  title="Client Registry · Minder"
  description="Astro shell for the Minder client registry."
  navTitle="Minder Client Registry"
  navDescription="Provision client keys, run connection checks, and copy onboarding snippets."
  sessionControls={true}
  navLinks={[
    { href: "/dashboard/clients", label: "Client Registry", tone: "primary" },
  ]}
>
  <section class="mb-8 flex flex-wrap items-end justify-between gap-4">
    <div class="space-y-3">
      <p class="eyebrow">Client Registry</p>
      <h1 class="text-5xl font-semibold tracking-tight text-stone-950">Manage MCP clients from the production dashboard.</h1>
      <p class="max-w-3xl text-lg leading-8 text-stone-700">
        Create clients, issue keys, test integrations, and copy onboarding snippets without leaving
        the dashboard. The detail pane stays in context so operational checks do not throw you out
        of the current screen.
      </p>
    </div>
  </section>

  <section class="grid gap-8 lg:grid-cols-[380px_minmax(0,1fr)]">
    <aside class="shell-card p-7">
      <p class="eyebrow">Create Client</p>
      <h2 class="mt-3 text-2xl font-semibold tracking-tight text-stone-950">Create a new MCP client</h2>
      <p class="mt-3 text-sm leading-6 text-stone-600">
        Minder will issue a new <code>mkc_...</code> key exactly once after creation. Keep scopes
        tight and prefer repo-specific access when possible.
      </p>

      <form id="create-client-form" class="mt-6 grid gap-4">
        <input id="client-name" class="rounded-2xl border border-stone-300 bg-white px-4 py-3" placeholder="Name" />
        <input id="client-slug" class="rounded-2xl border border-stone-300 bg-white px-4 py-3" placeholder="Slug" />
        <textarea id="client-description" class="min-h-28 rounded-2xl border border-stone-300 bg-white px-4 py-3" placeholder="Description"></textarea>
        <div class="flex flex-wrap gap-2">
          <button type="button" data-tool-preset="query" class="action-pill">Query Only</button>
          <button type="button" data-tool-preset="read" class="action-pill">Read Only</button>
          <button type="button" data-tool-preset="full" class="action-pill">Full Dev Assistant</button>
        </div>
        <label class="grid gap-2 text-sm text-stone-700">
          Tool scopes
          <select id="client-tool-scopes" multiple class="min-h-32 rounded-2xl border border-stone-300 bg-white px-4 py-3">
            <option value="minder_query">minder_query</option>
            <option value="minder_search_code">minder_search_code</option>
            <option value="minder_search_errors">minder_search_errors</option>
            <option value="minder_search">minder_search</option>
            <option value="minder_memory_recall">minder_memory_recall</option>
            <option value="minder_workflow_get">minder_workflow_get</option>
            <option value="minder_workflow_step">minder_workflow_step</option>
          </select>
        </label>
        <input id="client-repo-scopes" class="rounded-2xl border border-stone-300 bg-white px-4 py-3" placeholder="Repo scopes (comma-separated)" value="*" />
        <p id="create-client-status" class="min-h-6 text-sm text-stone-600"></p>
        <button type="submit" class="primary-pill w-full">Create client</button>
      </form>
      <div id="client-created-result" class="mt-5 hidden rounded-3xl border border-amber-200 bg-amber-50 p-4">
        <p class="eyebrow">New Client API Key</p>
        <code id="client-created-key" class="mt-3 block overflow-x-auto rounded-2xl bg-white px-4 py-3 text-sm text-stone-800"></code>
      </div>
    </aside>

    <div class="grid gap-6">
      <div id="client-registry" class="grid gap-4 md:grid-cols-2">
        <article class="shell-card p-6 text-sm text-stone-600">
          Loading client registry...
        </article>
      </div>

      <section id="client-detail-shell" class="shell-card hidden p-7">
        <div class="mb-8 flex flex-wrap items-center justify-between gap-4">
          <div class="space-y-3">
            <p class="eyebrow">Client Detail</p>
            <h2 id="detail-title" class="text-4xl font-semibold tracking-tight text-stone-950">Client</h2>
            <p class="max-w-3xl text-base leading-7 text-stone-700">
              Manage key lifecycle, onboarding snippets, and recent activity for the selected client.
            </p>
          </div>
          <a href="/dashboard/clients" class="action-pill">Back to registry</a>
        </div>

        <div class="grid gap-8 lg:grid-cols-[360px_minmax(0,1fr)]">
          <aside class="shell-card p-7">
            <p class="eyebrow">Lifecycle</p>
            <h3 class="mt-3 text-2xl font-semibold tracking-tight text-stone-950">Key management</h3>
            <div class="mt-6 grid gap-3">
              <button id="rotate-client-key" type="button" class="primary-pill w-full">Issue new client key</button>
              <button id="revoke-client-key" type="button" class="action-pill w-full">Revoke all keys</button>
            </div>
            <label class="mt-5 block">
              <span class="mb-2 block text-sm font-medium text-stone-800">Connection test API key</span>
              <input id="connection-api-key" class="w-full rounded-2xl border border-stone-300 bg-white px-4 py-3" placeholder="mkc_..." />
            </label>
            <button id="test-client-connection" type="button" class="action-pill mt-3 w-full">Run connection test</button>
            <p id="detail-status" class="mt-4 min-h-6 text-sm text-stone-600"></p>
            <div id="rotated-key-result" class="mt-4 hidden rounded-3xl border border-amber-200 bg-amber-50 p-4">
              <p class="eyebrow">New Client API Key</p>
              <code id="rotated-key-value" class="mt-3 block overflow-x-auto rounded-2xl bg-white px-4 py-3 text-sm text-stone-800"></code>
            </div>
          </aside>

          <div class="grid gap-6">
            <section class="shell-card p-7">
              <p class="eyebrow">Onboarding</p>
              <h3 class="mt-3 text-2xl font-semibold tracking-tight text-stone-950">Copy-ready MCP snippets</h3>
              <p class="mt-3 max-w-3xl text-sm leading-6 text-stone-600">
                Each snippet is rendered in a readable full-width card with a dedicated copy action.
              </p>
              <div id="onboarding-snippets" class="mt-6 grid gap-4">
                <article class="rounded-3xl border border-stone-300 bg-stone-50/80 p-4 text-sm text-stone-600">Select a client to load snippets.</article>
              </div>
            </section>

            <section class="shell-card p-7">
              <p class="eyebrow">Recent Activity</p>
              <h3 class="mt-3 text-2xl font-semibold tracking-tight text-stone-950">Audit events</h3>
              <div id="activity-feed" class="mt-6 grid gap-3">
                <div class="rounded-2xl border border-stone-300 bg-stone-50/80 px-4 py-3 text-sm text-stone-600">Select a client to load activity.</div>
              </div>
            </section>
          </div>
        </div>
      </section>
    </div>
  </section>
  <script src="../../scripts/clients-page.ts"></script>
</DashboardLayout>
