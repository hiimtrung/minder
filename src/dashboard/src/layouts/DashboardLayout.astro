---
import "../styles/global.css";
import Footer from "../components/ui/Footer.astro";
import CommonModal from "../components/CommonModal.astro";

interface Props {
  title: string;
  description?: string;
  navTitle?: string;
  navDescription?: string;
  showPageIntro?: boolean;
  navLinks?: Array<{
    href: string;
    label: string;
    tone?: "primary" | "secondary";
    currentDetail?: boolean;
  }>;
  sessionControls?: boolean;
}

const {
  title,
  description = "Minder dashboard shell",
  navTitle = "Minder Dashboard",
  navDescription = "Admin setup, login, client management, and onboarding on one port.",
  showPageIntro = true,
  navLinks = [],
  sessionControls = false,
} = Astro.props;

const DEFAULT_NAV = [
  { href: "/dashboard", label: "Home" },
  { href: "/dashboard/clients", label: "Clients" },
  { href: "/dashboard/repositories", label: "Repositories" },
  { href: "/dashboard/chat", label: "Chat" },
  { href: "/dashboard/skills", label: "Skills" },
  { href: "/dashboard/memories", label: "Memories" },
  { href: "/dashboard/prompts", label: "Prompts" },
  { href: "/dashboard/workflows", label: "Workflows" },
  { href: "/dashboard/users", label: "Users" },
  { href: "/dashboard/observability", label: "Observability" },
];

const effectiveNav = navLinks.length > 0 ? navLinks : DEFAULT_NAV;
const currentPath = Astro.url.pathname;

const isLinkActive = (href: string, currentDetail?: boolean) => {
  if (currentDetail) return true;

  // Normalize path by stripping backend-injected prefixes (e.g. /v1/admin)
  // to ensure active state detection works both in dev and prod/backend mounts.
  const normalizedPath = currentPath.replace(/^\/v[0-9]+\/admin/, "") || "/";
  const path = normalizedPath.replace(/\/$/, "") || "/";
  const target = href.replace(/\/$/, "") || "/";

  if (target === "/dashboard") {
    return path === "/dashboard" || path === "/dashboard/index.html";
  }
  return path.startsWith(target);
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href="/dashboard/favicon.png" />

    <!-- Design system fonts: Fraunces (display) + Inter (body) + JetBrains Mono (code) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;9..144,600;9..144,700&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
    />
  </head>
  <body>
    <div class="flex min-h-screen flex-col">
      <header class="pt-4 pb-2">
        <div class="u-page-container">
          <div
            class="shell-card flex flex-wrap items-center justify-between gap-4 px-5 py-3 md:px-6"
          >
            <a href="/dashboard" class="group flex min-w-0 items-center gap-3">
              <div
                class="flex h-10 w-10 items-center justify-center rounded-xl bg-amber-800 text-white shadow-md transition-transform group-hover:scale-105"
              >
                <span class="font-display text-lg font-bold">M</span>
              </div>
              <div class="flex min-w-0 flex-col">
                <span
                  class="font-display truncate text-base font-semibold tracking-tight text-stone-900"
                >
                  {navTitle}
                </span>
                <span
                  class="text-[10px] font-bold tracking-[0.2em] text-stone-500 uppercase"
                >
                  Control Plane
                </span>
              </div>
            </a>

            {
              effectiveNav.length > 0 && (
                <nav class="hidden flex-wrap items-center gap-1 md:flex">
                  {effectiveNav.map((link: any) => (
                    <a
                      href={link.href}
                      class="nav-link"
                      data-active={
                        isLinkActive(link.href, link.currentDetail)
                          ? "true"
                          : "false"
                      }
                    >
                      {link.label}
                    </a>
                  ))}
                </nav>
              )
            }

            {
              sessionControls && (
                <div class="flex items-center gap-3">
                  <span id="dashboard-session-badge" class="session-badge">
                    Checking...
                  </span>
                  <button
                    id="dashboard-logout-button"
                    type="button"
                    class="action-pill u-btn-sm"
                  >
                    Logout
                  </button>
                </div>
              )
            }
          </div>

          {
            effectiveNav.length > 0 && (
              <nav class="mt-3 flex flex-wrap items-center gap-2 md:hidden">
                {effectiveNav.map((link: any) => (
                  <a
                    href={link.href}
                    class={
                      isLinkActive(link.href, link.currentDetail)
                        ? "primary-pill u-btn-sm"
                        : "action-pill u-btn-sm"
                    }
                  >
                    {link.label}
                  </a>
                ))}
              </nav>
            )
          }
        </div>
      </header>

      <main class="flex-1">
        <div class="u-page-container u-page-stack">
          {
            showPageIntro && (
              <div class="mb-8 flex flex-col gap-2">
                <h1 class="u-page-hero-title">{title}</h1>
                <p class="u-page-hero-sub">{navDescription}</p>
              </div>
            )
          }
          <slot />
        </div>
      </main>

      <Footer showHealth={sessionControls} />

      <div
        id="dashboard-toast-region"
        class="pointer-events-none fixed right-6 bottom-6 z-50 flex max-w-sm flex-col gap-3"
      >
      </div>
      <CommonModal />
    </div>
    {sessionControls && <script src="../scripts/session-header.ts" />}
  </body>
</html>
