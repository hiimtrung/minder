---
interface Props {
  id: string;
  tone?: "neutral" | "success" | "warning" | "danger";
  class?: string;
}

const { id, tone = "neutral", class: className = "" } = Astro.props;

const toneClass =
  tone === "success"
    ? "u-status-success"
    : tone === "warning"
      ? "u-status-warning"
      : tone === "danger"
        ? "u-status-danger"
        : "";
---

<p id={id} class={`u-status ${toneClass} ${className}`}></p>

<style is:global>
  .u-status {
    min-height: 1.25rem;
    font-size: 0.875rem;
    color: rgb(87 83 78);
    font-family: var(--font-sans);
  }
  .u-status-success { color: rgb(4 120 87); }
  .u-status-warning { color: rgb(180 83 9); }
  .u-status-danger  { color: rgb(159 18 57); }
</style>
