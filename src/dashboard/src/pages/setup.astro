---
import DashboardLayout from "../layouts/DashboardLayout.astro";
import Card from "../components/ui/Card.astro";
import PageHero from "../components/ui/PageHero.astro";
import Field from "../components/ui/Field.astro";
import Input from "../components/ui/Input.astro";
import Button from "../components/ui/Button.astro";
import FormStatus from "../components/ui/FormStatus.astro";
import ResultCallout from "../components/ui/ResultCallout.astro";
---

<DashboardLayout
  title="Initial Setup · Minder"
  description="Initial setup shell for the Astro-based Minder dashboard."
  navTitle="Minder Setup"
  navDescription="Create the first admin account, then store the bootstrap key safely."
  navLinks={[
    { href: "/dashboard/login", label: "Admin Login", tone: "secondary" },
  ]}
  showPageIntro={false}
>
  <section class="u-split-hero lg:grid-cols-[0.95fr_1.05fr] lg:items-start">
    <Card padding="lg" class="u-page-shell">
      <PageHero
        eyebrow="First-Run Setup"
        title="Create the first Minder admin"
        description="This is the browser-first bootstrap flow for a fresh Minder deployment. It creates the first admin and reveals the bootstrap API key exactly once."
        class="mb-0"
      />
      <ul class="mt-6 space-y-3 text-sm leading-6 text-stone-700">
        <li>Creates the first admin only when no admin exists yet.</li>
        <li>
          Set a password here so you can sign in with
          <strong>username&nbsp;+ password</strong> going forward.
        </li>
        <li>Reveals the bootstrap API key exactly once after creation.</li>
        <li>
          Redirects future visits back to the login flow once setup is complete.
        </li>
      </ul>
    </Card>

    <Card as="section" padding="lg">
      <form id="setup-form" class="grid gap-5">
        <Field label="Username" htmlFor="setup-username">
          <Input id="setup-username" placeholder="admin" />
        </Field>
        <Field label="Email" htmlFor="setup-email">
          <Input
            id="setup-email"
            type="email"
            placeholder="admin@example.com"
          />
        </Field>
        <Field label="Display name" htmlFor="setup-display-name">
          <Input id="setup-display-name" placeholder="Platform Admin" />
        </Field>
        <Field label="Password" htmlFor="setup-password">
          <Input
            id="setup-password"
            type="password"
            placeholder="Min. 8 characters"
          />
        </Field>
        <Field label="Confirm password" htmlFor="setup-password-confirm">
          <Input
            id="setup-password-confirm"
            type="password"
            placeholder="Repeat password"
          />
        </Field>
        <FormStatus id="setup-status" />
        <Button type="submit" variant="primary" fullWidth>
          Create initial admin
        </Button>
      </form>
      <ResultCallout
        id="setup-result"
        tone="amber"
        eyebrow="Bootstrap API Key"
        class="mt-6"
      >
        <p class="mt-2 text-sm text-stone-600">
          You can also sign in with your username + password. Keep this key as a
          recovery fallback.
        </p>
        <code
          id="setup-api-key"
          class="mt-3 block overflow-x-auto rounded-2xl bg-white px-4 py-3 text-sm text-stone-800"
        ></code>
        <Button
          href="/dashboard/login"
          variant="primary"
          fullWidth
          class="mt-5 text-center"
        >
          Go to login →
        </Button>
      </ResultCallout>
    </Card>
  </section>
  <script src="../scripts/setup-page.ts"></script>
</DashboardLayout>
