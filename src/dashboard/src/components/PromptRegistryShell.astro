---
import DashboardLayout from "../layouts/DashboardLayout.astro";
import PageHero from "./ui/PageHero.astro";
import Toolbar from "./ui/Toolbar.astro";
import Field from "./ui/Field.astro";
import Input from "./ui/Input.astro";
import Textarea from "./ui/Textarea.astro";
import Button from "./ui/Button.astro";
import FormStatus from "./ui/FormStatus.astro";
---

<DashboardLayout
  title="Prompt Registry · Minder"
  description="Manage MCP prompts, polish drafts with minder AI, and preview reusable prompt templates."
  navTitle="Minder Dashboard"
  navDescription="Create, refine, and publish prompt templates that become available to MCP clients at runtime."
  sessionControls={true}
  showPageIntro={false}
>
  <PageHero
    eyebrow="Prompt Registry"
    title="Manage MCP prompts."
    description="Author prompt templates, polish them with the minder AI runtime, and publish changes directly into the server prompt registry."
  />

  <section class="u-grid-sidebar">
    <aside class="shell-card p-6">
      <div class="flex items-center justify-between gap-3">
        <div>
          <p class="eyebrow">Editor</p>
          <h2
            class="font-display mt-2 text-xl font-semibold tracking-tight text-stone-950"
          >
            Prompt draft
          </h2>
        </div>
        <Button id="prompt-reset-button" size="sm" variant="ghost">
          New draft
        </Button>
      </div>

      <form id="prompt-form" class="mt-5 grid gap-4">
        <input id="prompt-id" type="hidden" />
        <Field label="Name" htmlFor="prompt-name">
          <Input id="prompt-name" placeholder="debug_assistant" />
        </Field>
        <Field label="Title" htmlFor="prompt-title">
          <Input id="prompt-title" placeholder="Debug Assistant" />
        </Field>
        <Field label="Description" htmlFor="prompt-description">
          <Textarea
            id="prompt-description"
            placeholder="What should this prompt help the model accomplish?"
          />
        </Field>
        <Field
          label="Arguments"
          htmlFor="prompt-arguments"
        >
          <Input id="prompt-arguments" placeholder="error, context, repo_name" />
          <span slot="hint">
            Comma-separated placeholder names used as <code
              >&#123;placeholder&#125;</code
            > in the template.
          </span>
          <div
            id="prompt-argument-hints"
            class="min-h-6 text-xs text-stone-500"
          >
          </div>
        </Field>

        <Field label="Content template" htmlFor="prompt-template">
          <Textarea
            id="prompt-template"
            variant="code"
            placeholder="## Task\nInvestigate {error} with context from {repo_name}."
          />
        </Field>

        <div class="flex flex-wrap gap-3">
          <Button id="prompt-polish-button">Polish with AI</Button>
          <Button type="submit" variant="primary" class="flex-1 min-w-[180px]">
            Save prompt
          </Button>
        </div>
        <p id="prompt-editor-llm" class="min-h-5 text-xs text-stone-500"></p>
        <FormStatus id="prompt-editor-status" />
      </form>
    </aside>

    <div class="grid gap-5">
      <Toolbar
        idPrefix="prompt"
        title="Registry"
        description="Selecting a card loads it into the editor. Saving immediately syncs the MCP prompt registry for new and updated prompts."
        searchPlaceholder="Semantic quick search prompts"
      >
        <Button slot="leading" id="prompt-refresh-button" size="sm">
          Refresh list
        </Button>
      </Toolbar>

      <section class="grid gap-5 2xl:grid-cols-2">
        <div id="prompt-registry" class="grid gap-4">
          <article class="u-placeholder-card">Loading prompts...</article>
        </div>

        <aside class="shell-card p-6">
          <p class="eyebrow">Preview</p>
          <h2
            class="font-display mt-2 text-xl font-semibold tracking-tight text-stone-950"
          >
            Render template
          </h2>
          <p class="mt-2 text-sm leading-6 text-stone-600">
            Supply sample JSON values to preview the final prompt text after
            placeholder substitution. The editor auto-detects keys from the
            prompt template and scaffolds this JSON for you.
          </p>

          <Field
            label="Sample variables (JSON)"
            htmlFor="prompt-preview-variables"
            class="mt-4"
          >
            <Textarea
              id="prompt-preview-variables"
              variant="code"
              value={'{ "request": "Do some think", "context": "Fix some bug" }'}
            />
          </Field>

          <Button id="prompt-preview-button" class="mt-3">
            Render preview
          </Button>
          <FormStatus id="prompt-preview-status" class="mt-3" />

          <pre
            id="prompt-preview-output"
            class="font-mono-ui mt-3 min-h-[220px] overflow-auto rounded-xl border border-stone-200 bg-stone-950 px-4 py-4 text-sm leading-6 text-stone-100">Choose a prompt to preview its rendered output.</pre>
        </aside>
      </section>
    </div>
  </section>

  <script src="../scripts/prompts-page.ts"></script>
</DashboardLayout>
