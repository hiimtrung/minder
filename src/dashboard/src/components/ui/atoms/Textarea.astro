---
interface Props {
  id?: string;
  name?: string;
  value?: string;
  placeholder?: string;
  rows?: number;
  required?: boolean;
  disabled?: boolean;
  variant?: "default" | "large" | "code";
  class?: string;
}

const {
  id,
  name,
  value,
  placeholder,
  rows,
  required = false,
  disabled = false,
  variant = "default",
  class: className = "",
} = Astro.props;

const variantClass =
  variant === "large"
    ? "u-textarea-lg"
    : variant === "code"
      ? "u-textarea-code u-textarea-lg"
      : "";
---

<textarea
  id={id}
  name={name}
  rows={rows}
  required={required}
  disabled={disabled}
  placeholder={placeholder}
  class={`u-textarea ${variantClass} ${className}`}
>{value}</textarea>

<style is:global>
  .u-textarea {
    display: block;
    width: 100%;
    border-radius: 0.625rem;
    border: 1px solid rgb(214 211 209);
    background: white;
    padding: 0.5rem 0.875rem;
    font-size: 0.875rem;
    color: rgb(28 25 23);
    outline: none;
    transition: border-color 150ms, box-shadow 150ms;
    min-height: 80px;
    line-height: 1.55;
    resize: vertical;
    font-family: var(--font-sans);
  }
  .u-textarea::placeholder { color: rgb(168 162 158); }
  .u-textarea:hover { border-color: rgb(168 162 158); }
  .u-textarea:focus {
    border-color: rgb(180 83 9);
    box-shadow: 0 0 0 3px var(--color-brand-ring);
  }
  .u-textarea:disabled { cursor: not-allowed; background: rgb(250 250 249); color: rgb(168 162 158); }
  .u-textarea-lg { min-height: 220px; }
  .u-textarea-code { font-family: var(--font-mono); font-size: 0.8125rem; }
</style>
