---
import DashboardLayout from "../layouts/DashboardLayout.astro";
import DetailHeader from "./ui/DetailHeader.astro";
import Card from "./ui/Card.astro";
import Field from "./ui/Field.astro";
import Input from "./ui/Input.astro";
import Textarea from "./ui/Textarea.astro";
import Button from "./ui/Button.astro";
import FormStatus from "./ui/FormStatus.astro";
import ResultCallout from "./ui/ResultCallout.astro";

interface Props {
  clientId?: string;
}

const { clientId = "" } = Astro.props;
const detailHref = clientId
  ? `/dashboard/clients/${encodeURIComponent(clientId)}`
  : "/dashboard/clients";
---

<DashboardLayout
  title="Client Detail · Minder"
  description="Dedicated Astro shell for Minder client detail operations."
  navTitle="Minder Dashboard"
  navDescription="Operate one client with full breadcrumb context, lifecycle controls, and onboarding assets."
  sessionControls={true}
  showPageIntro={false}
>
  <DetailHeader
    breadcrumb={[
      { href: "/dashboard", label: "Dashboard" },
      { href: "/dashboard/clients", label: "Clients" },
      { label: "Client Detail" },
    ]}
    eyebrow="Client Detail"
    title="Loading client..."
    titleId="detail-title"
    description="Operate one MCP client without the registry list in the way. Rotate keys, run connection tests, copy onboarding templates, and review audit activity from a dedicated screen."
  >
    <Button slot="actions" href="/dashboard/clients" size="sm">
      Back to registry
    </Button>
    <Button slot="actions" href="/dashboard" size="sm">Dashboard home</Button>
  </DetailHeader>

  <section class="mb-6 shell-card flex flex-wrap items-center justify-between gap-4 px-6 py-4">
    <div>
      <p class="text-sm font-medium text-stone-900">Navigator</p>
      <p class="mt-1 text-sm text-stone-600">
        Stay on this client-specific route for key lifecycle work, then return
        to the registry to choose another integration.
      </p>
    </div>
    <div class="flex flex-wrap gap-2">
      <Button href="/dashboard/clients" size="sm">All clients</Button>
      <Button
        href={detailHref}
        variant="primary"
        size="sm"
        extraAttrs={{ "data-current-detail-link": true }}
      >
        Current detail
      </Button>
    </div>
  </section>

  <section id="client-detail-shell" class="u-grid-sidebar">
    <aside class="space-y-5">
      <!-- Key management -->
      <Card padding="lg">
        <p class="eyebrow">Lifecycle</p>
        <h2
          class="font-display mt-2 text-xl font-semibold tracking-tight text-stone-950"
        >
          Key management
        </h2>
        <div class="mt-5 grid gap-3">
          <Button id="rotate-client-key" variant="primary" fullWidth>
            Issue new client key
          </Button>
          <Button id="revoke-client-key" fullWidth>Revoke all keys</Button>
        </div>
        <Field
          label="Connection test API key"
          htmlFor="connection-api-key"
          class="mt-5"
        >
          <Input id="connection-api-key" placeholder="mkc_..." />
        </Field>
        <Button id="test-client-connection" fullWidth class="mt-3">
          Run connection test
        </Button>
        <FormStatus id="detail-status" class="mt-4" />
        <ResultCallout
          id="rotated-key-result"
          tone="amber"
          eyebrow="New Client API Key"
          class="mt-4"
        >
          <code
            id="rotated-key-value"
            class="font-mono-ui mt-3 block overflow-x-auto rounded-xl bg-white px-4 py-3 text-sm text-stone-800"
          ></code>
        </ResultCallout>
      </Card>

      <!-- Edit client -->
      <Card padding="lg">
        <div class="flex items-start justify-between gap-3">
          <div>
            <p class="eyebrow">Edit Client</p>
            <h2
              class="font-display mt-2 text-xl font-semibold tracking-tight text-stone-950"
            >
              Name, description &amp; scopes
            </h2>
          </div>
          <Button
            id="refresh-tools"
            size="sm"
            variant="ghost"
            title="Refresh tool list from server"
          >
            Refresh tools
          </Button>
        </div>

        <form id="edit-client-form" class="mt-5 grid gap-4">
          <Field label="Name" htmlFor="edit-client-name">
            <Input id="edit-client-name" placeholder="Client name" />
          </Field>

          <Field label="Description" htmlFor="edit-client-description">
            <Textarea
              id="edit-client-description"
              placeholder="Short description of this client's purpose"
            />
          </Field>

          <div class="grid gap-2 text-sm text-stone-700">
            <div class="flex items-center justify-between gap-2">
              <span class="u-field-label mb-0">Tool scopes</span>
              <div class="flex flex-wrap gap-2">
                <Button
                  size="sm"
                  extraAttrs={{ "data-edit-preset": "query" }}
                >
                  Query Only
                </Button>
                <Button size="sm" extraAttrs={{ "data-edit-preset": "read" }}>
                  Read Only
                </Button>
                <Button size="sm" extraAttrs={{ "data-edit-preset": "all" }}>
                  All
                </Button>
                <Button id="edit-select-none" size="sm">None</Button>
              </div>
            </div>
            <div
              id="edit-tool-scopes"
              class="max-h-80 min-h-32 overflow-y-auto rounded-xl border border-stone-300 bg-white p-2"
            >
              <p class="px-1 text-sm text-stone-400">Loading tools...</p>
            </div>
          </div>

          <FormStatus id="edit-client-status" />
          <Button type="submit" variant="primary" fullWidth>
            Save changes
          </Button>
        </form>
      </Card>
    </aside>

    <div class="grid gap-5">
      <Card padding="lg">
        <p class="eyebrow">Onboarding</p>
        <h2
          class="font-display mt-2 text-xl font-semibold tracking-tight text-stone-950"
        >
          Copy-ready MCP snippets
        </h2>
        <p class="mt-2 max-w-3xl text-sm leading-6 text-stone-600">
          Each integration now lives in its own collapsible block with a
          preferred remote setup tab, optional local stdio fallback tabs where
          relevant, and dedicated copy actions for full configs or server-entry
          snippets.
        </p>
        <div id="onboarding-snippets" class="mt-5 grid gap-4">
          <article class="u-placeholder-card">Loading snippets...</article>
        </div>
      </Card>

      <Card padding="lg">
        <p class="eyebrow">Recent Activity</p>
        <h2
          class="font-display mt-2 text-xl font-semibold tracking-tight text-stone-950"
        >
          Audit events
        </h2>
        <div id="activity-feed" class="mt-5 grid gap-3">
          <div class="u-placeholder-card">Loading activity...</div>
        </div>
      </Card>
    </div>
  </section>

  <script src="../scripts/clients-page.ts"></script>
</DashboardLayout>
