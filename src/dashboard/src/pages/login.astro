---
import DashboardLayout from "../layouts/DashboardLayout.astro";
---

<DashboardLayout
  title="Admin Login · Minder"
  description="Browser login shell for the Astro-based Minder dashboard."
  navTitle="Minder Admin Login"
  navDescription="Sign in with your username and password to open the dashboard."
  navLinks={[]}
>
  <section class="grid gap-8 lg:grid-cols-[1.1fr_0.9fr] lg:items-center">
    <div class="space-y-5">
      <p class="eyebrow">Admin Access</p>
      <h1 class="max-w-3xl text-5xl font-semibold tracking-tight text-stone-950">
        Sign into Minder without leaving the browser.
      </h1>
      <p class="max-w-2xl text-lg leading-8 text-stone-700">
        The dashboard uses an <code>HttpOnly</code> cookie-backed admin session. Sign
        in with your username and password, then manage clients, workflows, and activity
        from one place.
      </p>
    </div>

    <div class="shell-card p-8">
      <div class="mb-6">
        <p class="eyebrow">Admin Login</p>
        <h2 class="mt-3 text-2xl font-semibold tracking-tight text-stone-950">
          Sign in with username &amp; password
        </h2>
      </div>

      <!-- Primary: username + password -->
      <form id="login-form" class="space-y-4">
        <label class="block">
          <span class="mb-2 block text-sm font-medium text-stone-800">Username</span>
          <input
            id="login-username"
            type="text"
            autocomplete="username"
            placeholder="admin"
            class="w-full rounded-2xl border border-stone-300 bg-white px-4 py-3 text-stone-900 outline-none transition focus:border-amber-700"
          />
        </label>
        <label class="block">
          <span class="mb-2 block text-sm font-medium text-stone-800">Password</span>
          <input
            id="login-password"
            type="password"
            autocomplete="current-password"
            placeholder="••••••••"
            class="w-full rounded-2xl border border-stone-300 bg-white px-4 py-3 text-stone-900 outline-none transition focus:border-amber-700"
          />
        </label>
        <p id="login-status" class="min-h-6 text-sm text-stone-600"></p>
        <button type="submit" class="primary-pill w-full">Continue to dashboard</button>
      </form>

      <!-- Fallback: API key (advanced / recovery) -->
      <details class="mt-5">
        <summary
          class="cursor-pointer select-none text-sm text-stone-500 hover:text-stone-700"
        >
          Sign in with API key instead
        </summary>
        <form id="apikey-form" class="mt-4 space-y-3">
          <label class="block">
            <span class="mb-2 block text-sm font-medium text-stone-800">Admin API key</span>
            <input
              id="api-key"
              type="password"
              placeholder="mk_..."
              class="w-full rounded-2xl border border-stone-300 bg-white px-4 py-3 text-stone-900 outline-none transition focus:border-amber-700"
            />
          </label>
          <p id="apikey-status" class="min-h-6 text-sm text-stone-600"></p>
          <button type="submit" class="action-pill w-full">Sign in with API key</button>
        </form>
      </details>

      <!-- Shown only when no admin users exist yet (fresh install) -->
      <p id="setup-hint" class="mt-5 hidden text-center text-sm text-stone-500">
        Fresh install?
        <a href="/dashboard/setup" class="font-medium text-amber-700 hover:underline"
          >Complete first-time setup →</a
        >
      </p>
    </div>
  </section>
  <script src="../scripts/login-page.ts"></script>
</DashboardLayout>
