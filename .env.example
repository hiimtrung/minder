MINDER_SERVER__HOST=0.0.0.0
MINDER_SERVER__PORT=8801
MINDER_MONGODB__URI=mongodb://localhost:27017
MINDER_REDIS__URI=redis://localhost:6379/0
MINDER_VECTOR_STORE__URI=http://localhost:19530
MINDER_RELATIONAL_STORE__PROVIDER=mongodb
MINDER_VECTOR_STORE__PROVIDER=milvus
MINDER_LLM__PROVIDER=litert
MINDER_LLM__LITERT_MODEL_PATH=~/.minder/models/gemma-4-E2B-it.litertlm
MINDER_LLM__LITERT_BACKEND=cpu
MINDER_LLM__LITERT_CACHE_DIR=~/.minder/cache/litert
MINDER_EMBEDDING__PROVIDER=fastembed
MINDER_EMBEDDING__FASTEMBED_MODEL=mixedbread-ai/mxbai-embed-large-v1
MINDER_EMBEDDING__FASTEMBED_CACHE_DIR=~/.minder/cache/fastembed
MINDER_EMBEDDING__DIMENSIONS=1024
MINDER_CACHE__PROVIDER=redis
MINDER_WORKFLOW__ORCHESTRATION_RUNTIME=langgraph
