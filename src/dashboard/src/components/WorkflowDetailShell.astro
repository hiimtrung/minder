---
import DashboardLayout from "../layouts/DashboardLayout.astro";

interface Props {
  workflowId?: string;
}

const { workflowId = "" } = Astro.props;
const detailHref = workflowId
  ? `/dashboard/workflows/${encodeURIComponent(workflowId)}`
  : "/dashboard/workflows";
---

<DashboardLayout
  title="Workflow Detail · Minder"
  description="Edit a workflow definition — steps, enforcement, and gate conditions."
  navTitle="Minder Workflow Detail"
  navDescription="Operate one workflow definition with full step editor and enforcement controls."
  sessionControls={true}
  navLinks={[
    { href: "/dashboard", label: "Dashboard Home", tone: "secondary" },
    { href: "/dashboard/workflows", label: "Workflow Registry", tone: "secondary" },
    {
      href: detailHref,
      label: "Workflow Detail",
      tone: "primary",
      currentDetail: true,
    },
  ]}
>
  <section class="mb-8 space-y-6">
    <nav
      aria-label="Breadcrumb"
      class="flex flex-wrap items-center gap-2 text-sm text-stone-600"
    >
      <a href="/dashboard" class="transition hover:text-stone-950">Dashboard</a>
      <span aria-hidden="true">/</span>
      <a href="/dashboard/workflows" class="transition hover:text-stone-950"
        >Workflow Registry</a
      >
      <span aria-hidden="true">/</span>
      <span class="font-medium text-stone-950">Workflow Detail</span>
    </nav>

    <div class="flex flex-wrap items-end justify-between gap-4">
      <div class="space-y-3">
        <p class="eyebrow">Workflow Detail</p>
        <h1
          id="workflow-detail-title"
          class="text-5xl font-semibold tracking-tight text-stone-950"
        >
          Loading workflow...
        </h1>
        <p class="max-w-3xl text-lg leading-8 text-stone-700">
          Edit the step sequence, gate conditions, and enforcement level for
          this workflow. Changes take effect immediately for any repository
          that has this workflow assigned.
        </p>
      </div>
      <div class="flex flex-wrap gap-2">
        <a href="/dashboard/workflows" class="action-pill">Back to registry</a>
        <a href="/dashboard" class="action-pill">Dashboard home</a>
      </div>
    </div>
  </section>

  <section class="grid gap-8 lg:grid-cols-[420px_minmax(0,1fr)]">
    <!-- Edit panel -->
    <aside class="space-y-6">
      <section class="shell-card p-7">
        <p class="eyebrow">Edit Workflow</p>
        <h2 class="mt-3 text-2xl font-semibold tracking-tight text-stone-950">
          Name, description &amp; enforcement
        </h2>

        <form id="edit-workflow-form" class="mt-6 grid gap-4">
          <label class="grid gap-2 text-sm text-stone-700">
            Name
            <input
              id="edit-workflow-name"
              class="rounded-2xl border border-stone-300 bg-white px-4 py-3 text-stone-900"
              placeholder="Workflow name"
            />
          </label>

          <label class="grid gap-2 text-sm text-stone-700">
            Description
            <textarea
              id="edit-workflow-description"
              class="min-h-20 rounded-2xl border border-stone-300 bg-white px-4 py-3 text-stone-900"
              placeholder="Short description of this workflow's purpose"
            ></textarea>
          </label>

          <label class="grid gap-2 text-sm text-stone-700">
            Enforcement
            <select
              id="edit-workflow-enforcement"
              class="rounded-2xl border border-stone-300 bg-white px-4 py-3 text-stone-900"
            >
              <option value="strict">Strict — block on gate failure</option>
              <option value="advisory">Advisory — warn only</option>
              <option value="off">Off — no enforcement</option>
            </select>
          </label>

          <p id="edit-workflow-status" class="min-h-6 text-sm text-stone-600"></p>
          <button type="submit" class="primary-pill w-full">Save changes</button>
        </form>
      </section>

      <!-- Danger zone -->
      <section class="shell-card p-7">
        <p class="eyebrow">Danger Zone</p>
        <h2 class="mt-3 text-2xl font-semibold tracking-tight text-stone-950">
          Delete workflow
        </h2>
        <p class="mt-3 text-sm leading-6 text-stone-600">
          Permanently remove this workflow definition. Any repositories that
          reference it will lose their workflow assignment.
        </p>
        <button
          id="delete-workflow-button"
          type="button"
          class="action-pill mt-5 w-full border-red-300 text-red-700 hover:border-red-400 hover:bg-red-50"
        >
          Delete this workflow
        </button>
        <p id="delete-workflow-status" class="mt-3 min-h-6 text-sm text-red-600"></p>
      </section>
    </aside>

    <!-- Steps editor -->
    <div class="grid gap-6">
      <section class="shell-card p-7">
        <div class="flex items-center justify-between gap-4">
          <div>
            <p class="eyebrow">Steps</p>
            <h2 class="mt-3 text-2xl font-semibold tracking-tight text-stone-950">
              Step sequence editor
            </h2>
          </div>
          <button
            id="add-step-detail-button"
            type="button"
            class="action-pill shrink-0 text-xs">+ Add step</button
          >
        </div>
        <p class="mt-3 text-sm leading-6 text-stone-600">
          Steps execute in order. Each step can optionally declare a gate
          condition that must pass before the agent advances.
        </p>
        <div id="step-editor-list" class="mt-6 grid gap-3">
          <div
            class="rounded-2xl border border-stone-300 bg-stone-50/80 px-4 py-3 text-sm text-stone-600"
          >
            Loading steps...
          </div>
        </div>
        <div class="mt-4 flex justify-end">
          <button id="save-steps-button" type="button" class="primary-pill"
            >Save steps</button
          >
        </div>
        <p id="steps-status" class="mt-3 min-h-6 text-sm text-stone-600"></p>
      </section>
    </div>
  </section>
  <script src="../scripts/workflows-page.ts"></script>
</DashboardLayout>
